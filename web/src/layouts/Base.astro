---
// Базовый layout: дизайн-система PRISM + общая шапка/подвал на всех страницах.
// Тему ставим до рендера (без вспышки). `active` подсвечивает пункт меню.
import '../styles/styles.css';
import '../styles/scrollbars.css';
import '../styles/code.css';
import '../styles/prose.css';
import SiteHeader from '../components/SiteHeader.jsx';
import Footer from '../components/Footer.astro';
import data from '../data/leaderboard.json';

interface Props {
  title?: string;
  description?: string;
  active?: 'leaderboard' | 'methodology' | 'tasks' | 'docs';
  ogImage?: string;
  jsonLd?: any[];
}
const {
  title = 'PRISM — многомерная оценка генерации кода 1С',
  description = 'Исполняемый бенчмарк кода 1С (BSL): код запускается по-настоящему и оценивается по четырём осям SMOP — Syntax · Meaning · Optimization · Platform.',
  active = 'leaderboard',
  ogImage = 'og/home.png', // обложка по умолчанию; страницы моделей передают свою
  jsonLd = [],
} = Astro.props;
const version = data.meta?.version || '';
const base = import.meta.env.BASE_URL;
const canonical = new URL(Astro.url.pathname, Astro.site || Astro.url.origin).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site || Astro.url.origin).href : undefined;
const siteUrl = (Astro.site || Astro.url.origin).toString().replace(/\/$/, '');
// site-wide schema.org (WebSite); конкретная страница добавляет свои объекты через prop jsonLd
const schemas = [
  { '@context': 'https://schema.org', '@type': 'WebSite', name: 'PRISM', url: siteUrl, inLanguage: 'ru', description },
  ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd]),
];
---

<!doctype html>
<html lang="ru" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- подтверждение прав вебмастера в поисковиках -->
    <meta name="google-site-verification" content="RCxZweGu9mby3MjHEcEW-sKEvwJh8SqPKti4M0vB8XQ" />
    <meta name="yandex-verification" content="7dbaa226ce70f262" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}assets/lockdark.png`} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="PRISM" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
    <script is:inline>
      try {
        const t = localStorage.getItem('prism-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      } catch (e) {}
    </script>
    {schemas.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}
  </head>
  <body>
    <SiteHeader client:load active={active} version={version} repo={data.meta?.repo} />
    <slot />
    <Footer />
  </body>
</html>
