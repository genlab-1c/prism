Функция РазобратьФИО(Знач СтрокаФИО) Экспорт

	Результат = Новый Структура("Фамилия, Имя, Отчество, Инициалы, ФИОКраткое", "", "", "", "", "");
	
	СтрокаФИО = СокрЛП(СтрокаФИО);
	МассивЧастей = СтрРазделить(СтрокаФИО, " ", Ложь);
	КоличествоЧастей = МассивЧастей.Количество();
	
	Если КоличествоЧастей > 0 Тогда
		Результат.Фамилия = МассивЧастей[0];
	КонецЕсли;
	
	Если КоличествоЧастей > 1 Тогда
		Результат.Имя = МассивЧастей[1];
		Результат.Инициалы = Лев(Результат.Имя, 1) + ".";
	КонецЕсли;
	
	Если КоличествоЧастей > 2 Тогда
		Результат.Отчество = МассивЧастей[2];
		Результат.Инициалы = Результат.Инициалы + Лев(Результат.Отчество, 1) + ".";
	КонецЕсли;
	
	Результат.ФИОКраткое = СокрЛП(Результат.Фамилия + " " + Результат.Инициалы);
	
	Возврат Результат;

