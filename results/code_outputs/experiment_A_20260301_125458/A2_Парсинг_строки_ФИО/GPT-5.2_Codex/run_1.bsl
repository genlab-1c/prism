	МассивСлов = Новый Массив;
	Если СтрокаФИО = Неопределено Тогда
		СтрокаФИО = "";
	КонецЕсли;
	Для Каждого Часть Из СтрРазделить(СокрЛП(СтрокаФИО), " ") Цикл
