// Процедура распределяет общее количество списываемого товара по записям регистра "Товары на складах"
// в хронологическом порядке (FIFO), используя стандартные поля регистра.
// Параметры:
//  ТаблицаСписания - ТаблицаЗначений: Номенклатура (СправочникСсылка.Номенклатура), Количество (Число)
//  Склад - СправочникСсылка.Склады
// Возвращаемое значение:
//  ТаблицаЗначений: Номенклатура, Характеристика, Серия, Назначение, Помещение, Количество
Процедура СписатьТоварыПоFIFO(ТаблицаСписания, Склад) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ТаблицаСписания.Номенклатура КАК Номенклатура,
		|	ТаблицаСписания.Количество КАК Количество
		|ПОМЕСТИТЬ ВТ_Списание
		|ИЗ
		|	&ТаблицаСписания КАК ТаблицаСписания
		|;
		|
		|////////////////////////////////////////////////////////////////////////////////
		|ВЫБРАТЬ
		|	Остатки.Номенклатура КАК Номенклатура,
		|	Остатки.Характеристика КАК Характеристика,
		|	Остатки.Назначение КАК Назначение,
		|	Остатки.Серия КАК Серия,
		|	Остатки.Помещение КАК Помещение,
		|	Остатки.ВНаличииОстаток КАК КоличествоОстаток,
		|	Остатки.Регистратор.МоментВремени КАК МоментПартии
		|ИЗ
		|	РегистрНакопления.ТоварыНаСкладах.ОстаткиИОбороты(
		|			,
		|			,
		|			Запись,
		|			,
		|			Склад = &Склад
		|				И Номенклатура В
		|					(ВЫБРАТЬ
		|						ВТ.Номенклатура
		|					ИЗ
		|						ВТ_Списание КАК ВТ)) КАК Остатки
		|ГДЕ
		|	Остатки.ВНаличииОстаток > 0
		|
		|УПОРЯДОЧИТЬ ПО
		|	МоментПартии";

	Запрос.УстановитьПараметр("ТаблицаСписания", ТаблицаСписания);
	Запрос.УстановитьПараметр("Склад", Склад);

	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();

	ТаблицаРаспределения = Новый ТаблицаЗначений;
	ТаблицаРаспределения.Колонки.Добавить("Номенклатура");
	ТаблицаРаспределения.Колонки.Добавить("Характеристика");
	ТаблицаРаспределения.Колонки.Добавить("Назначение");
	ТаблицаРаспределения.Колонки.Добавить("Серия");
	ТаблицаРаспределения.Колонки.Добавить("Помещение");
	ТаблицаРаспределения.Колонки.Добавить("Количество");

	Для Каждого СтрокаСписания Из ТаблицаСписания Цикл
		
		НужноСписать = СтрокаСписания.Количество;
		Выборка.Сбросить();
		
		Пока Выборка.НайтиСледующий(Новый Структура("Номенклатура", СтрокаСписания.Номенклатура)) И НужноСписать > 0 Цикл
			
			ДоступноВЗаписи = Выборка.КоличествоОстаток;
			СписываемИзЗаписи = Мин(НужноСписать, ДоступноВЗаписи);
			
			НоваяСтрока = ТаблицаРаспределения.Добавить();
			ЗаполнитьЗначенияСвойств(НоваяСтрока, Выборка);
			НоваяСтрока.Количество = СписываемИзЗаписи;
			
			НужноСписать = НужноСписать - СписываемИзЗаписи;
			
		КонецЦикла;
		
		Если НужноСписать > 0 Тогда
			ВызватьИсключение "Недостаточно остатка по номенклатуре: " + СтрокаСписания.Номенклатура + ". Не хватает: " + НужноСписать;
		КонецЕсли;
		
	КонецЦикла;

	Возврат ТаблицаРаспределения;

КонецПроцедуры
