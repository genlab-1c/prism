Процедура ЗаполнитьЦеныВТабличнойЧасти(ТабличнаяЧасть, ВыбранныйВидЦены, ДатаЦен)
	
	МассивНоменклатуры = ТабличнаяЧасть.ВыгрузитьКолонку("Номенклатура");
	
	Запрос = Новый Запрос;
	Запрос.Текст = 
		"ВЫБРАТЬ
		|	ЦеныНоменклатурыСрезПоследних.Номенклатура КАК Номенклатура,
		|	ЦеныНоменклатурыСрезПоследних.Цена КАК Цена,
		|	ЦеныНоменклатурыСрезПоследних.Валюта КАК Валюта
		|ИЗ
		|	РегистрСведений.ЦеныНоменклатуры.СрезПоследних(&ДатаЦен, ВидЦены = &ВидЦены И Номенклатура В (&МассивНоменклатуры)) КАК ЦеныНоменклатурыСрезПоследних";
	
	Запрос.УстановитьПараметр("ДатаЦен", ДатаЦен);
	Запрос.УстановитьПараметр("ВидЦены", ВыбранныйВидЦены);
	Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);
	
	РезультатЗапроса = Запрос.Выполнить();
	Выборка = РезультатЗапроса.Выбрать();
	
	СоответствиеЦен = Новый Соответствие;
	Пока Выборка.Следующий() Цикл
		СоответствиеЦен.Вставить(Выборка.Номенклатура, Выборка.Цена);
	КонецЦикла;
	
	Для Каждого СтрокаТовар Из ТабличнаяЧасть Цикл
		НайденнаяЦена = СоответствиеЦен.Получить(СтрокаТовар.Номенклатура);
		
		Если НайденнаяЦена <> Неопределено Тогда
			СтрокаТовар.Цена = НайденнаяЦена;
		Иначе
			СтрокаТовар.Цена = 0;
		КонецЕсли;
		
		// Пересчет суммы строки
		ДанныеСтроки = Новый Структура("КоличествоУпаковок, Цена, ПроцентРучнойСкидки");
		ЗаполнитьЗначенияСвойств(ДанныеСтроки, СтрокаТовар);
		
		СтрокаТовар.Сумма = ДанныеСтроки.КоличествоУпаковок * ДанныеСтроки.Цена;
		
		Если ТабличнаяЧасть.Колонки.Найти("СуммаРучнойСкидки") <> Неопределено Тогда
			СтрокаТовар.СуммаРучнойСкидки = СтрокаТовар.Сумма * (ДанныеСтроки.ПроцентРучнойСкидки / 100);
			СтрокаТовар.Сумма = СтрокаТовар.Сумма - СтрокаТовар.СуммаРучнойСкидки;
		КонецЕсли;
		
		Если ТабличнаяЧасть.Колонки.Найти("СтавкаНДС") <> Неопределено Тогда
			ПараметрыНДС = Новый Структура("Сумма, СтавкаНДС");
			ЗаполнитьЗначенияСвойств(ПараметрыНДС, СтрокаТовар);
			// В УТ11 расчет НДС обычно вынесен в общий модуль, здесь базовый расчет
			СтрокаТовар.СуммаНДС = ПараметрыНДС.Сумма * 0.2; // Упрощенно
		КонецЕсли;
	КонецЦикла;

КонецПроцедуры
