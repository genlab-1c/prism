# Ключи доступа к моделям для `prism generate`.
# Скопируй этот файл в .env (он в .gitignore и в репозиторий не попадёт) и заполни нужные.
# Какой ключ требуется — зависит от access.adapter модели в generation/models.yaml.
#
# Харнесс подхватывает .env АВТОМАТИЧЕСКИ (pydantic-settings, см. harness/settings.py) —
# ручной `source .env` больше не нужен. Переменная окружения, если задана, приоритетнее .env.

# OpenRouter — единый канал к Claude, GPT, Gemini и десяткам других (adapter: openrouter)
OPENROUTER_API_KEY=

# GigaChat, Сбер (adapter: gigachat)
GIGACHAT_AUTH_KEY=
# GIGACHAT_SCOPE=GIGACHAT_API_PERS      # по умолчанию персональный доступ

# Yandex Cloud (adapter: yandexgpt — YandexGPT/Alice; yandex_responses — gpt-oss, Qwen3.6)
YANDEX_API_KEY=
YANDEX_FOLDER_ID=

# Локальный OpenAI-совместимый сервер — Ollama / vLLM (adapter: openai_compat)
# ключ обычно не нужен, endpoint берётся из access.endpoint модели в models.yaml
# OPENAI_COMPAT_API_KEY=

# Прокси по группам каналов (необязательно). Формат: http(s)://[user:pass@]host:port
# RU — отечественный прокси для Yandex (yandexgpt, yandex_responses) и GigaChat:
# PRISM_PROXY_RU=http://127.0.0.1:3128
# INTL — зарубежный прокси для OpenRouter:
# PRISM_PROXY_INTL=http://127.0.0.1:1080

# ── Исполнение и ресурсы (необязательно) ──────────────────────────────────────
# Работают и из .env, и как переменные окружения (env приоритетнее; флаг CLI приоритетнее обоих).
# Песочница исполнения кода кандидата (по умолчанию docker — изоляция недоверенного кода ИИ):
# PRISM_RUNNER=docker            # ось M (OneScript): docker | local
# PRISM_BSL=docker               # оси S/O (BSL LS):  docker | local
# PRISM_JAVA=/usr/lib/jvm/java-21/bin/java   # путь к java 21+ для BSL LS в режиме local
# Параллелизм и лимиты контейнера 1С (категория B):
# PRISM_CONCURRENCY=4            # сколько кандидатов считать параллельно (по умолчанию ≤4)
# PRISM_ONEC_MEMORY=2g           # лимит памяти на контейнер 1С (docker --memory)
# PRISM_ONEC_CPUS=1              # лимит CPU на контейнер 1С (docker --cpus)
