// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A13: перебираем ВСЕ пары (начало, конец) вложенным циклом и суммируем отрезок —
// O(N²) явными циклами. Оптимум — алгоритм Кадане за один проход, O(N).
Функция МаксСуммаПодмассива(Массив) Экспорт
    Количество = Массив.Количество();
    Если Количество = 0 Тогда
        Возврат 0;
    КонецЕсли;
    ОбщийМакс = Массив[0];
    Для Начало = 0 По Количество - 1 Цикл
        Сумма = 0;
        Для Конец = Начало По Количество - 1 Цикл
            Сумма = Сумма + Массив[Конец];
            Если Сумма > ОбщийМакс Тогда
                ОбщийМакс = Сумма;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;
    Возврат ОбщийМакс;
КонецФункции
