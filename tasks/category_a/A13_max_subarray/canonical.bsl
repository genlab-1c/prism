// Эталон A13. Оптимум — алгоритм Кадане: один проход, поддерживаем максимум суммы,
// заканчивающейся на текущем элементе, и общий максимум. O(N).
Функция МаксСуммаПодмассива(Массив) Экспорт
    Если Массив.Количество() = 0 Тогда
        Возврат 0;
    КонецЕсли;
    ТекущийМакс = Массив[0];
    ОбщийМакс = Массив[0];
    Для Индекс = 1 По Массив.Количество() - 1 Цикл
        Элемент = Массив[Индекс];
        // продолжить текущий отрезок или начать новый с Элемента
        Если ТекущийМакс + Элемент > Элемент Тогда
            ТекущийМакс = ТекущийМакс + Элемент;
        Иначе
            ТекущийМакс = Элемент;
        КонецЕсли;
        Если ТекущийМакс > ОбщийМакс Тогда
            ОбщийМакс = ТекущийМакс;
        КонецЕсли;
    КонецЦикла;
    Возврат ОбщийМакс;
КонецФункции
