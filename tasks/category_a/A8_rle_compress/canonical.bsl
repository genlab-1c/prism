// Эталонное решение A8. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СжатьRLE(Строка) Экспорт
    Длина = СтрДлина(Строка);
    Если Длина = 0 Тогда
        Возврат "";
    КонецЕсли;

    Результат = "";
    ТекущийСимвол = Сред(Строка, 1, 1);
    Счетчик = 1;

    Для Индекс = 2 По Длина Цикл
        Символ = Сред(Строка, Индекс, 1);
        Если Символ = ТекущийСимвол Тогда
            Счетчик = Счетчик + 1;
        Иначе
            Результат = Результат + ТекущийСимвол + Формат(Счетчик, "ЧГ=");
            ТекущийСимвол = Символ;
            Счетчик = 1;
        КонецЕсли;
    КонецЦикла;

    // дописываем последнюю серию
    Результат = Результат + ТекущийСимвол + Формат(Счетчик, "ЧГ=");

    Возврат Результат;
КонецФункции
