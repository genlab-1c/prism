// Эталонное решение A10. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ЧислоВРимское(Число) Экспорт
    // проверка диапазона: вне 1..3999 → пустая строка
    Если Число < 1 Или Число > 3999 Тогда
        Возврат "";
    КонецЕсли;

    // таблица пар «значение → символы» от большего к меньшему
    Значения = Новый Массив;
    Значения.Добавить(1000); Значения.Добавить(900);
    Значения.Добавить(500);  Значения.Добавить(400);
    Значения.Добавить(100);  Значения.Добавить(90);
    Значения.Добавить(50);   Значения.Добавить(40);
    Значения.Добавить(10);   Значения.Добавить(9);
    Значения.Добавить(5);    Значения.Добавить(4);
    Значения.Добавить(1);

    // «Символы» — зарезервированный глобальный объект 1С/OneScript, поэтому Обозначения
    Обозначения = Новый Массив;
    Обозначения.Добавить("M");  Обозначения.Добавить("CM");
    Обозначения.Добавить("D");  Обозначения.Добавить("CD");
    Обозначения.Добавить("C");  Обозначения.Добавить("XC");
    Обозначения.Добавить("L");  Обозначения.Добавить("XL");
    Обозначения.Добавить("X");  Обозначения.Добавить("IX");
    Обозначения.Добавить("V");  Обозначения.Добавить("IV");
    Обозначения.Добавить("I");

    // жадный алгоритм: на каждом шаге вычитаем максимально возможное значение
    Остаток = Число;
    Результат = "";
    Для Индекс = 0 По Значения.Количество() - 1 Цикл
        Пока Остаток >= Значения[Индекс] Цикл
            Результат = Результат + Обозначения[Индекс];
            Остаток = Остаток - Значения[Индекс];
        КонецЦикла;
    КонецЦикла;

    Возврат Результат;
КонецФункции
