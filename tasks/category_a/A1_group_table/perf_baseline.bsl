// ЯКОРЬ perf_baseline: корректное, но нарочно медленное решение — тот капкан, в который
// падают модели. Ось O ОБЯЗАНА поставить ему низкий балл (≤4), иначе у задачи слепая зона.
// Капкан A1: для каждой строки ищем группу в результате через НайтиСтроки — O(N²)
// (инструментируется ПризмаНайтиСтроки). Оптимум — Соответствие за O(N).
Функция СгруппироватьТаблицу(Таблица, КолонкаГруппировки, КолонкаСуммы) Экспорт
    Результат = Новый ТаблицаЗначений;
    Результат.Колонки.Добавить(КолонкаГруппировки);
    Результат.Колонки.Добавить(КолонкаСуммы);
    Для Каждого Строка Из Таблица Цикл
        Ключ = Строка[КолонкаГруппировки];
        Отбор = Новый Структура(КолонкаГруппировки, Ключ);
        Найденные = Результат.НайтиСтроки(Отбор);
        Если Найденные.Количество() = 0 Тогда
            Новая = Результат.Добавить();
            Новая[КолонкаГруппировки] = Ключ;
            Новая[КолонкаСуммы] = Строка[КолонкаСуммы];
        Иначе
            Найденные[0][КолонкаСуммы] = Найденные[0][КолонкаСуммы] + Строка[КолонкаСуммы];
        КонецЕсли;
    КонецЦикла;
    Возврат Результат;
КонецФункции
