// Эталонное решение A2. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СгруппироватьТаблицу(Таблица, КолонкаГруппировки, КолонкаСуммы) Экспорт
    // один проход: ключ группировки -> накопленная сумма.
    // Соответствие даёт поиск/вставку за O(1) вместо НайтиСтроки в цикле (было O(n^2)).
    Суммы = Новый Соответствие;
    Для Каждого Строка Из Таблица Цикл
        Ключ = Строка[КолонкаГруппировки];
        Накоплено = Суммы.Получить(Ключ);
        Если Накоплено = Неопределено Тогда
            Суммы.Вставить(Ключ, Строка[КолонкаСуммы]);
        Иначе
            Суммы.Вставить(Ключ, Накоплено + Строка[КолонкаСуммы]);
        КонецЕсли;
    КонецЦикла;

    // собираем выходную таблицу (порядок строк не специфицирован, харнесс сравнивает без него)
    Результат = Новый ТаблицаЗначений;
    Результат.Колонки.Добавить(КолонкаГруппировки);
    Результат.Колонки.Добавить(КолонкаСуммы);
    Для Каждого Пара Из Суммы Цикл
        Новая = Результат.Добавить();
        Новая[КолонкаГруппировки] = Пара.Ключ;
        Новая[КолонкаСуммы] = Пара.Значение;
    КонецЦикла;

    Возврат Результат;
КонецФункции
