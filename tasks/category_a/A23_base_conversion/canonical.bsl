// Эталонное решение A23. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ВСистемуСчисления(Число, Основание) Экспорт
    // таблица цифр: индекс остатка задаёт символ ("0"..."9","A"..."F")
    Цифры = "0123456789ABCDEF";

    // особый случай — ноль (цикл ниже не выполнится ни разу)
    Если Число = 0 Тогда
        Возврат "0";
    КонецЕсли;

    Результат = "";
    Пока Число > 0 Цикл
        Остаток = Число % Основание;
        // Сред нумерует символы с 1, поэтому остаток + 1
        Символ = Сред(Цифры, Остаток + 1, 1);
        // младшая цифра дописывается В НАЧАЛО строки
        Результат = Символ + Результат;
        Число = Цел(Число / Основание);
    КонецЦикла;

    Возврат Результат;
КонецФункции
