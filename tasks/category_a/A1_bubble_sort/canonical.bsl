// Эталонное решение A1. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СортировкаПузырьком(ИсходныйМассив) Экспорт
    // копия — исходный массив не изменяем
    Результат = Новый Массив;
    Для Каждого Элемент Из ИсходныйМассив Цикл
        Результат.Добавить(Элемент);
    КонецЦикла;

    Для НомерПрохода = 0 По Результат.Количество() - 2 Цикл
        Для Индекс = 0 По Результат.Количество() - 2 - НомерПрохода Цикл
            Если Результат[Индекс] > Результат[Индекс + 1] Тогда
                Временное = Результат[Индекс];
                Результат[Индекс] = Результат[Индекс + 1];
                Результат[Индекс + 1] = Временное;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    Возврат Результат;
КонецФункции
