// Эталонное решение A5. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СкользящееСреднее(Массив, Окно) Экспорт
    Результат = Новый Массив;

    // окно больше длины массива — скользящих средних нет
    Если Окно > Массив.Количество() Тогда
        Возврат Результат;
    КонецЕсли;

    // сумма первого окна
    Сумма = 0;
    Для Смещение = 0 По Окно - 1 Цикл
        Сумма = Сумма + Массив[Смещение];
    КонецЦикла;
    Результат.Добавить(Сумма / Окно);

    // скользящее окно: на каждом шаге вычитаем ушедший слева элемент
    // и прибавляем вошедший справа — пересчёт суммы за O(1), весь проход O(n)
    // (вместо повторного суммирования окна, что давало O(n*Окно)).
    Для НачалоОкна = 1 По Массив.Количество() - Окно Цикл
        Сумма = Сумма - Массив[НачалоОкна - 1] + Массив[НачалоОкна + Окно - 1];
        Результат.Добавить(Сумма / Окно);
    КонецЦикла;

    Возврат Результат;
КонецФункции
