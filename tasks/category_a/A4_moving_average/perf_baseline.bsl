// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A4: для каждой позиции заново суммируем всё окно — O(N·Окно), а Окно ~ N/4 → O(N²).
// Оптимум — скользящая сумма (одно вычитание+сложение на шаг), O(N).
Функция СкользящееСреднее(Массив, Окно) Экспорт
    Результат = Новый Массив;
    Если Окно > Массив.Количество() Тогда
        Возврат Результат;
    КонецЕсли;
    Для НачалоОкна = 0 По Массив.Количество() - Окно Цикл
        Сумма = 0;
        Для Смещение = 0 По Окно - 1 Цикл
            Сумма = Сумма + Массив[НачалоОкна + Смещение];
        КонецЦикла;
        Результат.Добавить(Сумма / Окно);
    КонецЦикла;
    Возврат Результат;
КонецФункции
