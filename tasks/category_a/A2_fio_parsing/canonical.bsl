// Эталонное решение A2. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция РазобратьФИО(СтрокаФИО) Экспорт
    Части = СтрРазделить(СокрЛП(СтрокаФИО), " ", Ложь);
    Фамилия  = ?(Части.Количество() > 0, Части[0], "");
    Имя      = ?(Части.Количество() > 1, Части[1], "");
    Отчество = ?(Части.Количество() > 2, Части[2], "");

    Инициалы = ?(Имя = "", "", Лев(Имя, 1) + ".");
    Если Отчество <> "" Тогда
        Инициалы = Инициалы + Лев(Отчество, 1) + ".";
    КонецЕсли;

    Результат = Новый Структура;
    Результат.Вставить("Фамилия", Фамилия);
    Результат.Вставить("Имя", Имя);
    Результат.Вставить("Отчество", Отчество);
    Результат.Вставить("Инициалы", Инициалы);
    Результат.Вставить("ФИОКраткое", Фамилия + " " + Инициалы);
    Возврат Результат;
КонецФункции
