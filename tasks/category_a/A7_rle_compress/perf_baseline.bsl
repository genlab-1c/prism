// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A7: строим результат ПОСИМВОЛЬНОЙ склейкой строки в цикле — O(N²)
// (инструментируется ПризмаСклейка). Оптимум — массив кусков + СтрСоединить, O(N).
Функция СжатьRLE(Строка) Экспорт
    Длина = СтрДлина(Строка);
    Если Длина = 0 Тогда
        Возврат "";
    КонецЕсли;
    Результат = "";
    ТекущийСимвол = Сред(Строка, 1, 1);
    Счетчик = 1;
    Для Индекс = 2 По Длина Цикл
        Символ = Сред(Строка, Индекс, 1);
        Если Символ = ТекущийСимвол Тогда
            Счетчик = Счетчик + 1;
        Иначе
            Результат = Результат + ТекущийСимвол + Формат(Счетчик, "ЧГ=");
            ТекущийСимвол = Символ;
            Счетчик = 1;
        КонецЕсли;
    КонецЦикла;
    Результат = Результат + ТекущийСимвол + Формат(Счетчик, "ЧГ=");
    Возврат Результат;
КонецФункции
