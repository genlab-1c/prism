// Эталонное решение A21. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ЯвляютсяАнаграммами(Первая, Вторая) Экспорт
    // нормализация: нижний регистр и удаление пробелов
    Текст1 = НРег(СтрЗаменить(Первая, " ", ""));
    Текст2 = НРег(СтрЗаменить(Вторая, " ", ""));

    // разные длины — заведомо не анаграммы
    Если СтрДлина(Текст1) <> СтрДлина(Текст2) Тогда
        Возврат Ложь;
    КонецЕсли;

    // накопление счётчиков символов первой строки в соответствие
    Счётчики = Новый Соответствие;
    Для Индекс = 1 По СтрДлина(Текст1) Цикл
        Символ = Сред(Текст1, Индекс, 1);
        Текущее = Счётчики.Получить(Символ);
        Если Текущее = Неопределено Тогда
            Текущее = 0;
        КонецЕсли;
        Счётчики.Вставить(Символ, Текущее + 1);
    КонецЦикла;

    // вычитание символов второй строки; уход в минус = несовпадение мультимножеств
    Для Индекс = 1 По СтрДлина(Текст2) Цикл
        Символ = Сред(Текст2, Индекс, 1);
        Текущее = Счётчики.Получить(Символ);
        Если Текущее = Неопределено ИЛИ Текущее = 0 Тогда
            Возврат Ложь;
        КонецЕсли;
        Счётчики.Вставить(Символ, Текущее - 1);
    КонецЦикла;

    // длины равны и все счётчики обнулены — строки являются анаграммами
    Возврат Истина;
КонецФункции
