// Эталонное решение A13. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция НормализоватьТелефон(Телефон) Экспорт
    // Шаг 1. Собрать только цифры (перебор символов, проверка вхождения в "0123456789").
    Цифры = "";
    Для Позиция = 1 По СтрДлина(Телефон) Цикл
        Символ = Сред(Телефон, Позиция, 1);
        Если Найти("0123456789", Символ) > 0 Тогда
            Цифры = Цифры + Символ;
        КонецЕсли;
    КонецЦикла;

    // Шаг 2. Нормализовать к 11 цифрам, начинающимся с 7.
    Если СтрДлина(Цифры) = 11 И Сред(Цифры, 1, 1) = "8" Тогда
        // 11 цифр с ведущей 8 — заменить первую на 7.
        Цифры = "7" + Сред(Цифры, 2, 10);
    ИначеЕсли СтрДлина(Цифры) = 10 Тогда
        // 10 цифр — добавить 7 в начало.
        Цифры = "7" + Цифры;
    КонецЕсли;
    // Случай "11 цифр, первая 7" уже корректен и не требует изменений.

    // Шаг 3. Проверка: ровно 11 цифр и первая — 7. Иначе пустая строка.
    Если СтрДлина(Цифры) <> 11 ИЛИ Сред(Цифры, 1, 1) <> "7" Тогда
        Возврат "";
    КонецЕсли;

    // Шаг 4. Собрать строку формата "+7 (XXX) XXX-XX-XX".
    // Нумерация символов в BSL с 1: Цифры = "7" + код(3) + номер(7).
    Код        = Сред(Цифры, 2, 3);   // символы 2..4  -> "912"
    Часть1     = Сред(Цифры, 5, 3);   // символы 5..7  -> "345"
    Часть2     = Сред(Цифры, 8, 2);   // символы 8..9  -> "67"
    Часть3     = Сред(Цифры, 10, 2);  // символы 10..11 -> "89"

    Возврат "+7 (" + Код + ") " + Часть1 + "-" + Часть2 + "-" + Часть3;
КонецФункции
