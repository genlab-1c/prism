// Эталонное решение A25. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СдвинутьМассив(Массив, Сдвиг) Экспорт
    Н = Массив.Количество();

    // пустой массив — возвращаем новый пустой
    Если Н = 0 Тогда
        Возврат Новый Массив;
    КонецЕсли;

    // нормализуем сдвиг в диапазон [0, Н):
    // в BSL оператор % для отрицательного делимого даёт остаток со знаком делимого,
    // поэтому при НормСдвиг < 0 добавляем Н
    НормСдвиг = Сдвиг % Н;
    Если НормСдвиг < 0 Тогда
        НормСдвиг = НормСдвиг + Н;
    КонецЕсли;

    // сборка нового массива: сдвиг ВПРАВО — новый[i] = старый[(i - НормСдвиг + Н) % Н]
    Результат = Новый Массив;
    Для Индекс = 0 По Н - 1 Цикл
        ИсходныйИндекс = (Индекс - НормСдвиг + Н) % Н;
        Результат.Добавить(Массив[ИсходныйИндекс]);
    КонецЦикла;

    Возврат Результат;
КонецФункции
