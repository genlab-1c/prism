// Эталонное решение A18. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция СкобкиСбалансированы(Строка) Экспорт
    // Стек ожидаемых закрывающих скобок (вершина — последний элемент массива)
    Стек = Новый Массив;

    Для Индекс = 1 По СтрДлина(Строка) Цикл
        Символ = Сред(Строка, Индекс, 1);

        Если Символ = "(" Тогда
            Стек.Добавить(")");
        ИначеЕсли Символ = "[" Тогда
            Стек.Добавить("]");
        ИначеЕсли Символ = "{" Тогда
            Стек.Добавить("}");
        ИначеЕсли Символ = ")" ИЛИ Символ = "]" ИЛИ Символ = "}" Тогда
            // Закрывающая: стек должен быть непуст и вершина обязана совпасть
            Если Стек.Количество() = 0 Тогда
                Возврат Ложь;
            КонецЕсли;
            Вершина = Стек[Стек.Количество() - 1];
            Если Вершина <> Символ Тогда
                Возврат Ложь;
            КонецЕсли;
            Стек.Удалить(Стек.Количество() - 1);
        КонецЕсли;
        // Прочие символы игнорируются
    КонецЦикла;

    // Сбалансировано, если все открывающие были закрыты
    Возврат Стек.Количество() = 0;
КонецФункции
