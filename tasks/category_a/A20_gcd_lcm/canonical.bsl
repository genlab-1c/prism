// Эталонное решение A20. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция НодИНок(Первое, Второе) Экспорт
    // НОД алгоритмом Евклида (через остаток от деления)
    А = Первое;
    Б = Второе;
    Пока Б <> 0 Цикл
        Остаток = А % Б;
        А = Б;
        Б = Остаток;
    КонецЦикла;
    Нод = А;

    // НОК = произведение, делённое на НОД
    Нок = Первое * Второе / Нод;

    Результат = Новый Структура;
    Результат.Вставить("НОД", Нод);
    Результат.Вставить("НОК", Нок);
    Возврат Результат;
КонецФункции
