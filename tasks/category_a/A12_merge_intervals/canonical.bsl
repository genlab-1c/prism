// Эталонное решение A12. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ОбъединитьИнтервалы(Интервалы) Экспорт
    // копия во временный массив — исходные интервалы не мутируем
    Временные = Новый Массив;
    Для Каждого Интервал Из Интервалы Цикл
        Временные.Добавить(Интервал);
    КонецЦикла;

    // сортировка по началу интервала (пузырьком — для простоты и наглядности)
    Для НомерПрохода = 0 По Временные.Количество() - 2 Цикл
        Для Индекс = 0 По Временные.Количество() - 2 - НомерПрохода Цикл
            Если Временные[Индекс][0] > Временные[Индекс + 1][0] Тогда
                Перестановка = Временные[Индекс];
                Временные[Индекс] = Временные[Индекс + 1];
                Временные[Индекс + 1] = Перестановка;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    Результат = Новый Массив;
    Для Каждого Интервал Из Временные Цикл
        Начало = Интервал[0];
        Конец = Интервал[1];
        Если Результат.Количество() = 0 Тогда
            // первый интервал — кладём новую пару в результат
            НоваяПара = Новый Массив;
            НоваяПара.Добавить(Начало);
            НоваяПара.Добавить(Конец);
            Результат.Добавить(НоваяПара);
        Иначе
            Накопленный = Результат[Результат.Количество() - 1];
            // начало текущего <= конец накопленного: пересекаются или соприкасаются
            Если Начало <= Накопленный[1] Тогда
                Если Конец > Накопленный[1] Тогда
                    Накопленный[1] = Конец;
                КонецЕсли;
            Иначе
                НоваяПара = Новый Массив;
                НоваяПара.Добавить(Начало);
                НоваяПара.Добавить(Конец);
                Результат.Добавить(НоваяПара);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции
