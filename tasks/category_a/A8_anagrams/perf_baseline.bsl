// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A8: для каждого символа первой строки ищем его во второй через Найти и удаляем —
// O(N²) (инструментируется ПризмаНайти). Оптимум — счётчики символов в Соответствии, O(N).
Функция ЯвляютсяАнаграммами(Первая, Вторая) Экспорт
    Текст1 = НРег(СтрЗаменить(Первая, " ", ""));
    Текст2 = НРег(СтрЗаменить(Вторая, " ", ""));
    Если СтрДлина(Текст1) <> СтрДлина(Текст2) Тогда
        Возврат Ложь;
    КонецЕсли;
    // вторую строку — в массив оставшихся символов
    Остаток = Новый Массив;
    Для Индекс = 1 По СтрДлина(Текст2) Цикл
        Остаток.Добавить(Сред(Текст2, Индекс, 1));
    КонецЦикла;
    Для Индекс = 1 По СтрДлина(Текст1) Цикл
        Символ = Сред(Текст1, Индекс, 1);
        Позиция = Остаток.Найти(Символ);
        Если Позиция = Неопределено Тогда
            Возврат Ложь;
        КонецЕсли;
        Остаток.Удалить(Позиция);
    КонецЦикла;
    Возврат Остаток.Количество() = 0;
КонецФункции
