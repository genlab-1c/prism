// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A10: вставляем каждое значение в результат на своё место через Массив.Вставить.
// Позицию находим ДВОИЧНЫМ поиском (O(log n) — дёшево и видимо), поэтому вся стоимость
// сидит в сдвиге хвоста внутри Вставить — O(n) на вставку → O(N²). Этот сдвиг СКРЫТ во
// встроенной команде: без инструментирования Вставить счётчик его не видит, и капкан
// выглядит линейным (слепая зона cost_model). Оптимум — единая сортировка, O((n+k)·logN).
Функция ВставитьВОтсортированный(Отсортированный, Значения) Экспорт
    Результат = Новый Массив;
    Для Каждого Элемент Из Отсортированный Цикл
        Результат.Добавить(Элемент);
    КонецЦикла;
    Для Каждого Элемент Из Значения Цикл
        // двоичный поиск позиции вставки: первый индекс, где значение больше Элемент
        Лево = 0;
        Право = Результат.Количество();
        Пока Лево < Право Цикл
            Середина = Цел((Лево + Право) / 2);
            Если Результат[Середина] <= Элемент Тогда
                Лево = Середина + 1;
            Иначе
                Право = Середина;
            КонецЕсли;
        КонецЦикла;
        Результат.Вставить(Лево, Элемент);
    КонецЦикла;
    Возврат Результат;
КонецФункции
