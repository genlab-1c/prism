// Эталон A10. Оптимум — сложить всё в один набор и отсортировать встроенной сортировкой
// O((n+k)·log(n+k)); линейные копии — видимая работа, сама сортировка счётчику не видна.
// Исходные массивы не мутируем. Дубликаты сохраняются (в набор кладём каждый элемент).
Функция ВставитьВОтсортированный(Отсортированный, Значения) Экспорт
    ТЗ = Новый ТаблицаЗначений;
    ТЗ.Колонки.Добавить("Значение");
    Для Каждого Элемент Из Отсортированный Цикл
        Строка = ТЗ.Добавить();
        Строка.Значение = Элемент;
    КонецЦикла;
    Для Каждого Элемент Из Значения Цикл
        Строка = ТЗ.Добавить();
        Строка.Значение = Элемент;
    КонецЦикла;
    ТЗ.Сортировать("Значение");

    Результат = Новый Массив;
    Для Каждого Строка Из ТЗ Цикл
        Результат.Добавить(Строка.Значение);
    КонецЦикла;
    Возврат Результат;
КонецФункции
