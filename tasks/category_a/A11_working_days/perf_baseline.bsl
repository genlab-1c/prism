// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A11: идём ЦИКЛОМ ПО КАЖДОМУ ДНЮ периода и проверяем день недели/праздник — число
// итераций растёт линейно с длиной периода → O(N). Оптимум считает то же арифметикой за
// константу (p_opt = 0), поэтому цикл по дням — на класс хуже.
Функция РабочиеДни(ДатаНачала, ДатаОкончания, Праздники) Экспорт
    Если ДатаОкончания < ДатаНачала Тогда
        Возврат 0;
    КонецЕсли;
    Будни = 0;
    Текущая = ДатаНачала;
    Пока Текущая <= ДатаОкончания Цикл
        Если ДеньНедели(Текущая) <= 5 И Праздники.Найти(Текущая) = Неопределено Тогда
            Будни = Будни + 1;
        КонецЕсли;
        Текущая = Текущая + 86400;
    КонецЦикла;
    Возврат Будни;
КонецФункции
