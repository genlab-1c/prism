// Эталон A11. Оптимум — арифметика: число будней в периоде НЕ зависит от его длины,
// считается за константу (полные недели × 5 + добор по остатку), плюс проход по праздникам.
// Никакого цикла по дням — потому p_opt = 0 (работа не растёт с длиной периода).
Функция РабочиеДни(ДатаНачала, ДатаОкончания, Праздники) Экспорт
    Если ДатаОкончания < ДатаНачала Тогда
        Возврат 0;
    КонецЕсли;

    ВсегоДней = Цел((ДатаОкончания - ДатаНачала) / 86400) + 1;
    ПолныхНедель = Цел(ВсегоДней / 7);
    Остаток = ВсегоДней - ПолныхНедель * 7;
    Будни = ПолныхНедель * 5;

    // добираем будни в неполной неделе, начиная с дня недели ДатаНачала (1=Пн … 7=Вс)
    ДеньН = ДеньНедели(ДатаНачала);
    Для Смещение = 0 По Остаток - 1 Цикл
        Текущий = (ДеньН + Смещение - 1) % 7 + 1;
        Если Текущий <= 5 Тогда
            Будни = Будни + 1;
        КонецЕсли;
    КонецЦикла;

    // вычитаем праздники, попавшие в период И на будний день
    Для Каждого Праздник Из Праздники Цикл
        Если Праздник >= ДатаНачала И Праздник <= ДатаОкончания И ДеньНедели(Праздник) <= 5 Тогда
            Будни = Будни - 1;
        КонецЕсли;
    КонецЦикла;

    Возврат Будни;
КонецФункции
