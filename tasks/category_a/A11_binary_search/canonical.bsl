// Эталонное решение A11. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция БинарныйПоиск(Массив, Значение) Экспорт
    // двоичный поиск двумя указателями по отсортированному массиву
    Лево = 0;
    Право = Массив.Количество() - 1;

    Пока Лево <= Право Цикл
        // целочисленная середина диапазона
        Середина = Цел((Лево + Право) / 2);

        Если Массив[Середина] = Значение Тогда
            Возврат Середина;
        ИначеЕсли Массив[Середина] < Значение Тогда
            // искомое правее середины
            Лево = Середина + 1;
        Иначе
            // искомое левее середины
            Право = Середина - 1;
        КонецЕсли;
    КонецЦикла;

    // значение не найдено
    Возврат -1;
КонецФункции
