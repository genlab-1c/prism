// Эталонное решение A6. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ЧастотаСлов(Текст) Экспорт
    // регистр игнорируем — всё к нижнему
    Нормализованный = НРег(Текст);

    // знаки препинания и прочие не-буквы заменяем на пробел, чтобы они работали
    // как разделители слов. Символы копим в Массив и склеиваем один раз через
    // СтрСоединить — посимвольная конкатенация строки дала бы O(n^2) (строки неизменяемы).
    БукСимволы = Новый Массив;
    Для Позиция = 1 По СтрДлина(Нормализованный) Цикл
        Символ = Сред(Нормализованный, Позиция, 1);
        Если ЭтоБуква(Символ) Тогда
            БукСимволы.Добавить(Символ);
        Иначе
            БукСимволы.Добавить(" ");
        КонецЕсли;
    КонецЦикла;
    Очищенный = СтрСоединить(БукСимволы, "");

    // разбиваем по пробелам без пустых элементов
    Слова = СтрРазделить(Очищенный, " ", Ложь);

    Результат = Новый Структура;
    Для Каждого Слово Из Слова Цикл
        Если Слово = "" Тогда
            Продолжить;
        КонецЕсли;
        Текущее = 0;
        Если Результат.Свойство(Слово, Текущее) Тогда
            Результат.Вставить(Слово, Текущее + 1);
        Иначе
            Результат.Вставить(Слово, 1);
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции

// Возвращает Истина, если переданный одиночный символ — буква
// (русская либо латинская, в любом регистре).
Функция ЭтоБуква(Символ)
    Код = КодСимвола(Символ);
    // латиница A-Z / a-z
    Если (Код >= КодСимвола("A") И Код <= КодСимвола("Z"))
        ИЛИ (Код >= КодСимвола("a") И Код <= КодСимвола("z")) Тогда
        Возврат Истина;
    КонецЕсли;
    // кириллица а-я / А-Я и ё/Ё
    Если (Код >= КодСимвола("а") И Код <= КодСимвола("я"))
        ИЛИ (Код >= КодСимвола("А") И Код <= КодСимвола("Я"))
        ИЛИ Код = КодСимвола("ё") ИЛИ Код = КодСимвола("Ё") Тогда
        Возврат Истина;
    КонецЕсли;
    Возврат Ложь;
КонецФункции
