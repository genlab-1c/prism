// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A12: удаляем вхождения НА МЕСТЕ через Массив.Удалить в прямом цикле. Каждое удаление
// у начала сдвигает хвост массива — O(N) на удаление, а совпадений много → O(N²). Этот сдвиг
// СКРЫТ во встроенной команде: без инструментирования Удалить счётчик видит лишь линейный
// проход и капкан выглядит O(N). Расширенный cost_model (ПризмаУдалить) начисляет стоимость
// сдвига → капкан честно проседает. Оптимум — сборка нового массива за один проход, O(N).
Функция УбратьЗначение(Массив, Значение) Экспорт
    Результат = Новый Массив;
    Для Каждого Элемент Из Массив Цикл
        Результат.Добавить(Элемент);
    КонецЦикла;
    Индекс = 0;
    Пока Индекс < Результат.Количество() Цикл
        Если Результат[Индекс] = Значение Тогда
            Результат.Удалить(Индекс);
        Иначе
            Индекс = Индекс + 1;
        КонецЕсли;
    КонецЦикла;
    Возврат Результат;
КонецФункции
