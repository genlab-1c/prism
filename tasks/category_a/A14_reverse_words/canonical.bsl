// Эталон A14. Оптимум — разбить на слова, собрать их в обратном порядке в массив и склеить
// одним СтрСоединить. O(N), без квадратичной склейки. Пустые части (лишние пробелы) отброшены.
Функция РазвернутьСлова(Строка) Экспорт
    Слова = СтрРазделить(Строка, " ", Ложь);
    Обратные = Новый Массив;
    Индекс = Слова.Количество() - 1;
    Пока Индекс >= 0 Цикл
        Обратные.Добавить(Слова[Индекс]);
        Индекс = Индекс - 1;
    КонецЦикла;
    Возврат СтрСоединить(Обратные, " ");
КонецФункции
