// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A14: собираем результат ПОСЛОВНОЙ склейкой строки в цикле (идём по словам с конца
// и дописываем) — каждая дописка копирует всю накопленную строку → O(N²) (инструментируется
// ПризмаСклейка). Оптимум — массив + СтрСоединить, O(N).
Функция РазвернутьСлова(Строка) Экспорт
    Слова = СтрРазделить(Строка, " ", Ложь);
    Результат = "";
    Индекс = Слова.Количество() - 1;
    Пока Индекс >= 0 Цикл
        Если Результат <> "" Тогда
            Результат = Результат + " ";
        КонецЕсли;
        Результат = Результат + Слова[Индекс];
        Индекс = Индекс - 1;
    КонецЦикла;
    Возврат Результат;
КонецФункции
