// Эталонное решение A22. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ЦифровойКорень(Число) Экспорт
    Результат = Число;
    // Сворачиваем до одной цифры: пока больше 9 — суммируем цифры.
    // Ноль и любая одиночная цифра возвращаются как есть (цикл не выполнится).
    Пока Результат > 9 Цикл
        Сумма = 0;
        Текущее = Результат;
        Пока Текущее > 0 Цикл
            Сумма = Сумма + Текущее % 10;   // младшая цифра
            Текущее = Цел(Текущее / 10);     // отбрасываем младшую цифру
        КонецЦикла;
        Результат = Сумма;
    КонецЦикла;

    Возврат Результат;
КонецФункции
