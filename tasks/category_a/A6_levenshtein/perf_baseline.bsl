// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A6: наивная рекурсия без запоминания — O(3^длины), взрывается по числу вызовов.
// Оптимум сам квадратичен — динамика O(n·m), p_opt = 2.0; рекурсия много хуже → низкий балл.
Функция РасстояниеЛевенштейна(Строка1, Строка2) Экспорт
    Возврат РекРасстояние(Строка1, СтрДлина(Строка1), Строка2, СтрДлина(Строка2));
КонецФункции

Функция РекРасстояние(С1, i, С2, j)
    Если i = 0 Тогда
        Возврат j;
    КонецЕсли;
    Если j = 0 Тогда
        Возврат i;
    КонецЕсли;
    Если Сред(С1, i, 1) = Сред(С2, j, 1) Тогда
        Возврат РекРасстояние(С1, i - 1, С2, j - 1);
    КонецЕсли;
    Удаление = РекРасстояние(С1, i - 1, С2, j) + 1;
    Вставка  = РекРасстояние(С1, i, С2, j - 1) + 1;
    Замена   = РекРасстояние(С1, i - 1, С2, j - 1) + 1;
    Минимум = ?(Удаление < Вставка, Удаление, Вставка);
    Минимум = ?(Замена < Минимум, Замена, Минимум);
    Возврат Минимум;
КонецФункции
