// Эталонное решение A7. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
//
// Классическая динамика на полной матрице (Длина1+1) x (Длина2+1).
// Ячейка [i][j] — расстояние между префиксами Строка1[1..i] и Строка2[1..j].
Функция РасстояниеЛевенштейна(Строка1, Строка2) Экспорт
    Длина1 = СтрДлина(Строка1);
    Длина2 = СтрДлина(Строка2);

    // Базовые случаи: пустая строка → длина другой строки
    Если Длина1 = 0 Тогда
        Возврат Длина2;
    КонецЕсли;
    Если Длина2 = 0 Тогда
        Возврат Длина1;
    КонецЕсли;

    // Матрица как массив массивов; строки 0..Длина1, столбцы 0..Длина2
    Матрица = Новый Массив;
    Для i = 0 По Длина1 Цикл
        Ряд = Новый Массив;
        Для j = 0 По Длина2 Цикл
            Ряд.Добавить(0);
        КонецЦикла;
        Матрица.Добавить(Ряд);
    КонецЦикла;

    // Инициализация границ: превращение из/в пустую строку
    Для i = 0 По Длина1 Цикл
        Матрица[i][0] = i;
    КонецЦикла;
    Для j = 0 По Длина2 Цикл
        Матрица[0][j] = j;
    КонецЦикла;

    // Заполнение (нумерация символов в строках — с 1)
    Для i = 1 По Длина1 Цикл
        Символ1 = Сред(Строка1, i, 1);
        Для j = 1 По Длина2 Цикл
            Символ2 = Сред(Строка2, j, 1);

            СтоимостьЗамены = ?(Символ1 = Символ2, 0, 1);

            Удаление = Матрица[i - 1][j] + 1;
            Вставка  = Матрица[i][j - 1] + 1;
            Замена   = Матрица[i - 1][j - 1] + СтоимостьЗамены;

            // Минимум из трёх операций
            Минимум = ?(Удаление < Вставка, Удаление, Вставка);
            Минимум = ?(Замена < Минимум, Замена, Минимум);

            Матрица[i][j] = Минимум;
        КонецЦикла;
    КонецЦикла;

    Возврат Матрица[Длина1][Длина2];
КонецФункции
