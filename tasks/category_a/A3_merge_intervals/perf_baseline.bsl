// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A3: сортировка пузырьком O(N²) явными циклами вместо встроенной O(N·logN);
// слияние линейное. Оптимум — ТЗ.Сортировать + линейное слияние (p_opt = 1.1).
Функция ОбъединитьИнтервалы(Интервалы) Экспорт
    // копия в массив пар [начало, конец] — исходный не мутируем
    Пары = Новый Массив;
    Для Каждого Инт Из Интервалы Цикл
        П = Новый Массив;
        П.Добавить(Инт[0]);
        П.Добавить(Инт[1]);
        Пары.Добавить(П);
    КонецЦикла;

    // пузырьковая сортировка по началу — O(N²)
    Количество = Пары.Количество();
    Для i = 0 По Количество - 2 Цикл
        Для j = 0 По Количество - 2 - i Цикл
            Если Пары[j][0] > Пары[j + 1][0] Тогда
                Врем = Пары[j];
                Пары[j] = Пары[j + 1];
                Пары[j + 1] = Врем;
            КонецЕсли;
        КонецЦикла;
    КонецЦикла;

    // линейное слияние отсортированных интервалов
    Результат = Новый Массив;
    Для Каждого П Из Пары Цикл
        Если Результат.Количество() = 0 Тогда
            НоваяПара = Новый Массив;
            НоваяПара.Добавить(П[0]);
            НоваяПара.Добавить(П[1]);
            Результат.Добавить(НоваяПара);
        Иначе
            Накопленный = Результат[Результат.Количество() - 1];
            Если П[0] <= Накопленный[1] Тогда
                Если П[1] > Накопленный[1] Тогда
                    Накопленный[1] = П[1];
                КонецЕсли;
            Иначе
                НоваяПара = Новый Массив;
                НоваяПара.Добавить(П[0]);
                НоваяПара.Добавить(П[1]);
                Результат.Добавить(НоваяПара);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции
