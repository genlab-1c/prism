// Эталонное решение A4. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ОбъединитьИнтервалы(Интервалы) Экспорт
    // складываем интервалы в ТЗ с числовыми колонками и сортируем встроенной
    // сортировкой по началу — O(n*logN) вместо пузырька O(n^2);
    // исходный массив не мутируем (копируем в таблицу).
    ТЗ = Новый ТаблицаЗначений;
    ТЗ.Колонки.Добавить("Начало");
    ТЗ.Колонки.Добавить("Конец");
    Для Каждого Интервал Из Интервалы Цикл
        Стр = ТЗ.Добавить();
        Стр.Начало = Интервал[0];
        Стр.Конец = Интервал[1];
    КонецЦикла;
    ТЗ.Сортировать("Начало");

    // линейное слияние отсортированных интервалов
    Результат = Новый Массив;
    Для Каждого Стр Из ТЗ Цикл
        Начало = Стр.Начало;
        Конец = Стр.Конец;
        Если Результат.Количество() = 0 Тогда
            // первый интервал — кладём новую пару в результат
            НоваяПара = Новый Массив;
            НоваяПара.Добавить(Начало);
            НоваяПара.Добавить(Конец);
            Результат.Добавить(НоваяПара);
        Иначе
            Накопленный = Результат[Результат.Количество() - 1];
            // начало текущего <= конец накопленного: пересекаются или соприкасаются
            Если Начало <= Накопленный[1] Тогда
                Если Конец > Накопленный[1] Тогда
                    Накопленный[1] = Конец;
                КонецЕсли;
            Иначе
                НоваяПара = Новый Массив;
                НоваяПара.Добавить(Начало);
                НоваяПара.Добавить(Конец);
                Результат.Добавить(НоваяПара);
            КонецЕсли;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;
КонецФункции
