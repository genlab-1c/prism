// Эталонное решение A15. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция Транспонировать(Матрица) Экспорт
    Результат = Новый Массив;

    // пустая матрица → пустой массив
    Если Матрица.Количество() = 0 Тогда
        Возврат Результат;
    КонецЕсли;

    // число столбцов задаётся длиной первой строки
    КоличествоСтолбцов = Матрица[0].Количество();

    Для Столбец = 0 По КоличествоСтолбцов - 1 Цикл
        НоваяСтрока = Новый Массив;
        Для Строка = 0 По Матрица.Количество() - 1 Цикл
            НоваяСтрока.Добавить(Матрица[Строка][Столбец]);
        КонецЦикла;
        Результат.Добавить(НоваяСтрока);
    КонецЦикла;

    Возврат Результат;
КонецФункции
