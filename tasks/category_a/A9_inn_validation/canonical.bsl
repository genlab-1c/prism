// Эталонное решение A9. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ПроверитьИНН(ИНН) Экспорт
    // Пустую строку и нестроковый ввод сразу отбраковываем
    Если ТипЗнч(ИНН) <> Тип("Строка") Тогда
        Возврат Ложь;
    КонецЕсли;

    Длина = СтрДлина(ИНН);
    Если Длина <> 10 И Длина <> 12 Тогда
        Возврат Ложь;
    КонецЕсли;

    // Разбираем строку в массив цифр, попутно проверяя что все символы — цифры
    Цифры = Новый Массив;
    Для Позиция = 1 По Длина Цикл
        Символ = Сред(ИНН, Позиция, 1);
        Если Символ < "0" ИЛИ Символ > "9" Тогда
            Возврат Ложь;
        КонецЕсли;
        Цифры.Добавить(Число(Символ));
    КонецЦикла;

    Если Длина = 10 Тогда
        Веса = ВесаКоэффициенты("2,4,10,3,5,9,4,6,8");
        КонтрольнаяЦифра = ВычислитьКонтрольнуюЦифру(Цифры, Веса);
        Возврат КонтрольнаяЦифра = Цифры[9];
    Иначе
        // 12 знаков: две контрольные цифры (11-я и 12-я)
        Веса11 = ВесаКоэффициенты("7,2,4,10,3,5,9,4,6,8");
        Веса12 = ВесаКоэффициенты("3,7,2,4,10,3,5,9,4,6,8");
        Контрольная1 = ВычислитьКонтрольнуюЦифру(Цифры, Веса11);
        Контрольная2 = ВычислитьКонтрольнуюЦифру(Цифры, Веса12);
        Возврат Контрольная1 = Цифры[10] И Контрольная2 = Цифры[11];
    КонецЕсли;
КонецФункции

// Разбирает строку весовых коэффициентов вида "2,4,10,..." в массив чисел.
Функция ВесаКоэффициенты(СтрокаВесов)
    Результат = Новый Массив;
    Для Каждого Элемент Из СтрРазделить(СтрокаВесов, ",") Цикл
        Результат.Добавить(Число(Элемент));
    КонецЦикла;
    Возврат Результат;
КонецФункции

// Считает контрольную цифру: (сумма цифра*вес) % 11 % 10.
// Перебирает столько цифр, сколько задано весов.
Функция ВычислитьКонтрольнуюЦифру(Цифры, Веса)
    Сумма = 0;
    Для Индекс = 0 По Веса.Количество() - 1 Цикл
        Сумма = Сумма + Цифры[Индекс] * Веса[Индекс];
    КонецЦикла;
    Возврат Сумма % 11 % 10;
КонецФункции
