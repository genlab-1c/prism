// Эталонное решение A10. Назначение: референс + проверка корректности самих тестов
// (эталон должен проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ПростыеЧисла(Граница) Экспорт
    Результат = Новый Массив;

    // Простых чисел нет, если граница меньше 2
    Если Граница < 2 Тогда
        Возврат Результат;
    КонецЕсли;

    // Флаги «составное» для чисел 0..Граница; индекс = само число.
    // Новый Массив(Размер) создаёт массив, заполненный Неопределено;
    // трактуем Неопределено как «ещё не помечено составным» (т.е. кандидат в простые).
    Составное = Новый Массив(Граница + 1);

    // Решето Эратосфена: для каждого простого Делитель вычёркиваем его кратные.
    Делитель = 2;
    Пока Делитель * Делитель <= Граница Цикл
        Если Составное[Делитель] = Неопределено Тогда
            Кратное = Делитель * Делитель;
            Пока Кратное <= Граница Цикл
                Составное[Кратное] = Истина;
                Кратное = Кратное + Делитель;
            КонецЦикла;
        КонецЕсли;
        Делитель = Делитель + 1;
    КонецЦикла;

    // Собираем числа 2..Граница, не помеченные составными, в порядке возрастания.
    Число = 2;
    Пока Число <= Граница Цикл
        Если Составное[Число] = Неопределено Тогда
            Результат.Добавить(Число);
        КонецЕсли;
        Число = Число + 1;
    КонецЦикла;

    Возврат Результат;
КонецФункции
