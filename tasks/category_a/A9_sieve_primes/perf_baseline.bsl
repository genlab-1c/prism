// ЯКОРЬ perf_baseline: корректный, но нарочно медленный капкан для оси O (должна дать ≤4).
// Капкан A9: для каждого числа проверяем делимость на ВСЕ числа до него (не до корня) —
// O(N²) явным вложенным циклом. Оптимум — решето Эратосфена, ~O(N·loglogN) ≈ линейно.
Функция ПростыеЧисла(Граница) Экспорт
    Результат = Новый Массив;
    Число = 2;
    Пока Число <= Граница Цикл
        Простое = Истина;
        Делитель = 2;
        Пока Делитель < Число Цикл
            Если Число % Делитель = 0 Тогда
                Простое = Ложь;
            КонецЕсли;
            Делитель = Делитель + 1;
        КонецЦикла;
        Если Простое Тогда
            Результат.Добавить(Число);
        КонецЕсли;
        Число = Число + 1;
    КонецЦикла;
    Возврат Результат;
КонецФункции
