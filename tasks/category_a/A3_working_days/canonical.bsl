// Эталонное решение A3. Референс + проверка корректности самих тестов
// (эталон обязан проходить tests.yaml на 100%). Валидируется прогоном в OneScript.
Функция ПодсчитатьРабочиеДни(ДатаНачала, ДатаОкончания) Экспорт
    Результат = 0;
    Текущая = НачалоДня(ДатаНачала);
    Последняя = НачалоДня(ДатаОкончания);
    Пока Текущая <= Последняя Цикл
        Если ДеньНедели(Текущая) <= 5 Тогда      // 1=Пн … 5=Пт, 6/7 — выходные
            Результат = Результат + 1;
        КонецЕсли;
        Текущая = Текущая + 86400;               // +1 сутки (в секундах)
    КонецЦикла;
    Возврат Результат;
КонецФункции
