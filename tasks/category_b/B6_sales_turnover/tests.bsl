// Проверки B6 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Колонки результата у кандидата могут называться по-разному (Количество/Сумма
// или КоличествоОборот/СуммаОборот) — числа ищем устойчиво по смыслу колонки.

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар2 = Спр("Номенклатура", "Товар 2");
	СкладОсновной = Спр("Склады", "Основной склад");

	// Тест 1: обороты за февраль без склада → Товар1 суммирует обе февральские
	// продажи (Основной 5 + Резервный 7): Количество=12, Сумма=1200.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Дата(2026, 2, 1), Дата(2026, 2, 28));
		Стр1 = НайтиСтроку(Р1, Товар1);
		Если Стр1 <> Неопределено
			И ЧисловаяКолонка(Стр1, Р1, "Колич") = 12
			И ЧисловаяКолонка(Стр1, Р1, "Сумм") = 1200 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (февраль без склада); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: обороты за февраль по складу Основной → только продажа от 2026-02-15:
	// Товар1 Количество=5, Сумма=500.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Дата(2026, 2, 1), Дата(2026, 2, 28), СкладОсновной);
		Стр2 = НайтиСтроку(Р2, Товар1);
		Если Стр2 <> Неопределено
			И (ЧисловаяКолонка(Стр2, Р2, "Колич") = 5
			   Или ЧисловаяКолонка(Стр2, Р2, "Сумм") = 500) Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (февраль, склад Основной); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: обороты за весь квартал без склада → две строки (Товар1 и Товар2),
	// Товар1 Количество=22 (10 + 5 + 7).
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Дата(2026, 1, 1), Дата(2026, 3, 31));
		Стр3_1 = НайтиСтроку(Р3, Товар1);
		Стр3_2 = НайтиСтроку(Р3, Товар2);
		Если Р3.Количество() = 2
			И Стр3_1 <> Неопределено И Стр3_2 <> Неопределено
			И ЧисловаяКолонка(Стр3_1, Р3, "Колич") = 22 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (квартал, строк=" + Р3.Количество() + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Строка результата по номенклатуре — без привязки к имени колонки кандидата.
Функция НайтиСтроку(ТЗ, НоменклатураСсылка)
	Для Каждого Строка Из ТЗ Цикл
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Если Строка[Колонка.Имя] = НоменклатураСсылка Тогда
				Возврат Строка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Число из колонки, имя которой содержит ПодстрокаИмени («Колич»/«Сумм»);
// если такой нет — первая числовая колонка строки (устойчиво к именам кандидата).
Функция ЧисловаяКолонка(Строка, ТЗ, ПодстрокаИмени)
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Значение = Строка[Колонка.Имя];
		Если ТипЗнч(Значение) = Тип("Число")
			И Найти(ВРег(Колонка.Имя), ВРег(ПодстрокаИмени)) > 0 Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
