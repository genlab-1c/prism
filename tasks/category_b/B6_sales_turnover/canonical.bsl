// Эталон B6 под СИНТЕТИЧЕСКУЮ схему (Склад, Номенклатура, ресурсы Количество/Сумма).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Регистр «Продажи» — ОБОРОТНЫЙ: в виртуальной таблице .Обороты ресурсы получают
// суффикс «Оборот» → КоличествоОборот, СуммаОборот.
// Не использует поля, которых нет в синтетической схеме.

Функция ПолучитьОбороты(НачалоПериода, КонецПериода, Склад = Неопределено) Экспорт

    // Внутри параметров виртуальной таблицы .Обороты(...) условие пишется
    // по голому имени измерения — без алиаса таблицы. Склад — необязателен.
    Условие = "";
    Если ЗначениеЗаполнено(Склад) Тогда
        Условие = "Склад = &Склад";
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   ОборотыПродаж.Номенклатура КАК Номенклатура,
    |   ЕСТЬNULL(ОборотыПродаж.КоличествоОборот, 0) КАК Количество,
    |   ЕСТЬNULL(ОборотыПродаж.СуммаОборот, 0) КАК Сумма
    |ИЗ
    |   РегистрНакопления.Продажи.Обороты(&НачалоПериода, &КонецПериода, , " + Условие + ") КАК ОборотыПродаж";

    Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
    Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
    Если ЗначениеЗаполнено(Склад) Тогда
        Запрос.УстановитьПараметр("Склад", Склад);
    КонецЕсли;

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
