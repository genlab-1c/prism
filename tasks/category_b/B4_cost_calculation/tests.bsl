// Проверки B4 — родной формат раннера категории B (v1).
// {{ENTRY}} — функция кандидата: (МассивНоменклатуры, Склад, Дата) → ТЗ со средней ценой.
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Хол = Спр("Номенклатура", "Холодильник X");
	Болт = Спр("Номенклатура", "Болт М6");
	Скл = Спр("Склады", "Основной склад");
	М = Новый Массив; М.Добавить(Хол); М.Добавить(Болт);

	// Тест 1: средневзвешенная на раннюю дату — поздняя партия не учитывается.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(М, Скл, Дата(2026, 3, 1));
		Если ЗначениеПоНоменклатуре(Р1, Хол) = 175 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (средняя=" + ЗначениеПоНоменклатуре(Р1, Хол) + ", ждали 175); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: позиция без остатков — ноль.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(М, Скл, Дата(2026, 3, 1));
		Если ЗначениеПоНоменклатуре(Р2, Болт) = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (без остатков ждали 0); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: на позднюю дату входит третья партия — средняя меняется.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(М, Скл, Дата(2026, 7, 1));
		Если ЗначениеПоНоменклатуре(Р3, Хол) = 240 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (средняя=" + ЗначениеПоНоменклатуре(Р3, Хол) + ", ждали 240); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Средняя цена позиции: строка по колонке «Номенклатура» (имя задано промптом);
// значение — колонка с именем про среднюю/цену, запасной путь — первая числовая.
Функция ЗначениеПоНоменклатуре(ТЗ, Ссылка)
	Для Каждого Строка Из ТЗ Цикл
		Если Строка["Номенклатура"] = Ссылка Тогда
			ПервоеЧисло = Неопределено;
			Для Каждого Колонка Из ТЗ.Колонки Цикл
				Значение = Строка[Колонка.Имя];
				Если ТипЗнч(Значение) <> Тип("Число") Тогда Продолжить; КонецЕсли;
				Имя = ВРег(Колонка.Имя);
				Если СтрНайти(Имя, "СРЕДН") > 0 Или СтрНайти(Имя, "ЦЕН") > 0
					Или СтрНайти(Имя, "СЕБЕСТОИМОСТ") > 0 Тогда
					Возврат Значение;
				КонецЕсли;
				Если ПервоеЧисло = Неопределено Тогда ПервоеЧисло = Значение; КонецЕсли;
			КонецЦикла;
			Возврат ПервоеЧисло;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
