// Эталон B4 под синтетическую схему (ПартииТоваров: Склад, Номенклатура; Количество, Стоимость).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.

Функция РассчитатьСебестоимость(МассивНоменклатуры, Склад, ДатаРасчета) Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Остатки.Номенклатура КАК Номенклатура,
    |   ВЫБОР
    |       КОГДА ЕСТЬNULL(Остатки.КоличествоОстаток, 0) = 0 ТОГДА 0
    |       ИНАЧЕ Остатки.СтоимостьОстаток / Остатки.КоличествоОстаток
    |   КОНЕЦ КАК СредняяЦена
    |ИЗ
    |   РегистрНакопления.ПартииТоваров.Остатки(
    |       &ДатаРасчета, Склад = &Склад И Номенклатура В (&МассивНоменклатуры)) КАК Остатки";
    Запрос.УстановитьПараметр("ДатаРасчета", ДатаРасчета);
    Запрос.УстановитьПараметр("Склад", Склад);
    Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);

    Результат = Запрос.Выполнить().Выгрузить();

    // Позиции без остатков — нулевая средняя (виртуальная таблица их не возвращает).
    Для Каждого Номенклатура Из МассивНоменклатуры Цикл
        Если Результат.Найти(Номенклатура, "Номенклатура") = Неопределено Тогда
            Строка = Результат.Добавить();
            Строка.Номенклатура = Номенклатура;
            Строка.СредняяЦена = 0;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции
