// Эталон B17 под СИНТЕТИЧЕСКУЮ схему (регистр Взаиморасчеты в разрезе Договора,
// подчинённого Контрагентам). Обязан проходить tests.bsl на 100%.
// Ключевое: (1) отбор контрагента через реквизит измерения Договор.Владелец (своего
// измерения Контрагент нет); (2) долг — сумма ТОЛЬКО положительных остатков по договорам
// (аванс — отрицательный остаток — в долг не идёт).

Функция ДолгКонтрагента(Контрагент) Экспорт

	// ВТ остатков при проекции одного агрегата (без измерения) сворачивает остаток в
	// нетто по контрагенту → аванс «съест» долг. Поэтому подзапросом фиксируем остаток
	// В РАЗРЕЗЕ ДОГОВОРА, затем оставляем только положительные (долг) и суммируем.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(ПоДоговорам.Остаток), 0) КАК Долг
	|ИЗ
	|	(ВЫБРАТЬ
	|		Остатки.Договор КАК Договор,
	|		Остатки.СуммаОстаток КАК Остаток
	|	ИЗ
	|		РегистрНакопления.Взаиморасчеты.Остатки(, Договор.Владелец = &Контрагент) КАК Остатки) КАК ПоДоговорам
	|ГДЕ
	|	ПоДоговорам.Остаток > 0";

	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Долг;

КонецФункции
