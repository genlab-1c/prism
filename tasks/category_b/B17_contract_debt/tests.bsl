// Проверки B17 — родной формат раннера категории B (v1).
// СоздатьФикстуры() и Спр() генерируются из fixtures.yaml; ниже — только проверки.
// {{ENTRY}} — имя функции кандидата. Контракт: "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// Тест 1: у Альфы Д1 в долге (+700), Д2 в авансе (−300). Долг = 700 (аванс не входит).
	// Ловушка: наивная СУММА(СуммаОстаток) свернёт долг и аванс в 400.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Спр("Контрагенты", "ООО Альфа"));
		Если Р1 = 700 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидалось 700, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: у Беты один договор с долгом 400.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Спр("Контрагенты", "ООО Бета"));
		Если Р2 = 400 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось 400, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: у Гаммы договоров нет → долг 0.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Спр("Контрагенты", "ООО Гамма"));
		Если Р3 = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалось 0, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
