// Эталон B14 под СИНТЕТИЧЕСКУЮ схему (два регистра остатков: ТоварыНаСкладах с
// ресурсом ВНаличии и Резервы с ресурсом Зарезервировано).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Только поля синтетической схемы — ничего из УТ11.
//
// Суть и главная ловушка: свободный остаток = наличие - резерв, но товар без
// резерва не должен исчезнуть. Поэтому ЛЕВОЕ СОЕДИНЕНИЕ от таблицы наличия к
// таблице резервов и ЕСТЬNULL(...,0) на ресурсе резерва — иначе строка с
// отсутствующим резервом отвалится (NULL в соединении) или резерв станет NULL.

Функция ПолучитьСвободныйОстаток(МассивНоменклатуры, Склад) Экспорт

    // Условия пишутся ВНУТРИ параметров каждой виртуальной таблицы по ГОЛЫМ
    // именам измерений (без алиаса таблицы). Один и тот же фильтр на обе ВТ:
    // склад фиксирован, номенклатура — из переданного массива.
    Условие = "Склад = &Склад И Номенклатура В (&МассивНоменклатуры)";

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Наличие.Номенклатура КАК Номенклатура,
    |   ЕСТЬNULL(Наличие.ВНаличииОстаток, 0) - ЕСТЬNULL(Резерв.ЗарезервированоОстаток, 0) КАК Свободно
    |ИЗ
    |   РегистрНакопления.ТоварыНаСкладах.Остатки(, " + Условие + ") КАК Наличие
    |       ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Резервы.Остатки(, " + Условие + ") КАК Резерв
    |       ПО Наличие.Номенклатура = Резерв.Номенклатура";

    Запрос.УстановитьПараметр("Склад", Склад);
    Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
