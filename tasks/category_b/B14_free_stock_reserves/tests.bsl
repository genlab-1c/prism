// Проверки B14 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
//
// Смысл: свободный остаток = наличие - резерв. Главная ловушка задачи —
// товар БЕЗ резерва (Товар3) не должен исчезнуть из результата: правильное
// решение — ЛЕВОЕ СОЕДИНЕНИЕ двух ВТ остатков + ЕСТЬNULL на резерве.
// Имя числовой колонки у кандидата может отличаться от «Свободно», поэтому
// значение берём УСТОЙЧИВО — первой числовой колонкой строки.

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Склад  = Спр("Склады", "Основной склад");
	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар2 = Спр("Номенклатура", "Товар 2");
	Товар3 = Спр("Номенклатура", "Товар 3");

	// Тест 1: Товар1 — наличие 100, резерв 30 → свободно 70.
	Попытка
		М = Новый Массив; М.Добавить(Товар1);
		Р1 = КодКандидата.{{ENTRY}}(М, Склад);
		Строка = НайтиСтроку(Р1, Товар1);
		Если Строка = Неопределено Тогда
			Лог = Лог + "тест1 FAIL (строка Товар1 не найдена); ";
		ИначеЕсли ЧисловаяКолонка(Р1, Строка) = 70 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (свободно=" + Строка(ЧисловаяКолонка(Р1, Строка)) + ", ждали 70); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: Товар2 — наличие 50, резерв 50 → свободно 0 (граничный ноль).
	Попытка
		М = Новый Массив; М.Добавить(Товар2);
		Р2 = КодКандидата.{{ENTRY}}(М, Склад);
		Строка = НайтиСтроку(Р2, Товар2);
		Если Строка = Неопределено Тогда
			Лог = Лог + "тест2 FAIL (строка Товар2 не найдена); ";
		ИначеЕсли ЧисловаяКолонка(Р2, Строка) = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (свободно=" + Строка(ЧисловаяКолонка(Р2, Строка)) + ", ждали 0); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3 (ключевой): Товар3 — наличие 30, резерва НЕТ. Строка обязана
	// присутствовать, свободно = 30 (ЕСТЬNULL резерва → 0). Если решение делает
	// ВНУТРЕННЕЕ соединение или не обрабатывает NULL — строка пропадёт → FAIL.
	Попытка
		М = Новый Массив; М.Добавить(Товар3);
		Р3 = КодКандидата.{{ENTRY}}(М, Склад);
		Строка = НайтиСтроку(Р3, Товар3);
		Если Строка = Неопределено Тогда
			Лог = Лог + "тест3 FAIL (строка Товар3 потеряна — резерва нет); ";
		ИначеЕсли ЧисловаяКолонка(Р3, Строка) = 30 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (свободно=" + Строка(ЧисловаяКолонка(Р3, Строка)) + ", ждали 30); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Строка ТЗ, где колонка-номенклатура равна заданной ссылке. Имя колонки у
// кандидата может отличаться, поэтому сверяем значения всех колонок строки со
// ссылкой — первое совпадение и есть искомая номенклатура.
Функция НайтиСтроку(ТЗ, Номенклатура)
	Для Каждого Стр Из ТЗ Цикл
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Если Стр[Колонка.Имя] = Номенклатура Тогда
				Возврат Стр;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Первая числовая колонка строки — свободный остаток без привязки к имени
// колонки кандидата (как в B1).
Функция ЧисловаяКолонка(ТЗ, Строка)
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Значение = Строка[Колонка.Имя];
		Если ТипЗнч(Значение) = Тип("Число") Тогда Возврат Значение; КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
