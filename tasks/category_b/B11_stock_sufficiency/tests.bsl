// Проверки B11 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
//
// Смысл: чистый остаток = приход − расход (виртуальная таблица .Остатки нетит сама).
// Ловушка: у Товара1 было 100 прихода и 60 расхода → остаток 40, НЕ 100. Кандидат,
// считающий только приход, провалит тест3. Товар без движений → остаток 0 (пустая
// выборка, а не исключение). Кандидат возвращает Булево — сравниваем явно с Истина/Ложь.

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 4; Лог = "";
	СоздатьФикстуры();

	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар2 = Спр("Номенклатура", "Товар 2");   // без движений → остаток 0
	Склад  = Спр("Склады", "Основной склад");

	// Тест 1: требуется ровно остаток (40) → Истина (граница «больше либо равно»).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Товар1, Склад, 40);
		Если Р1 = Истина Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидалось Истина, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: требуется на единицу больше остатка (41) → Ложь.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Товар1, Склад, 41);
		Если Р2 = Ложь Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось Ложь, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3 (ловушка): приходов было 100, но с учётом расхода остаток 40.
	// Требуется 50 → Ложь. Кандидат, суммирующий только приход, вернёт Истина и провалится.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Товар1, Склад, 50);
		Если Р3 = Ложь Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (учёт расхода: остаток 40, ожидалось Ложь, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 4: товар без движений → остаток 0 (пустая выборка, не исключение).
	// Требуется 1 → Ложь.
	Попытка
		Р4 = КодКандидата.{{ENTRY}}(Товар2, Склад, 1);
		Если Р4 = Ложь Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест4 FAIL (товар без движений: остаток 0, ожидалось Ложь, получено " + Строка(Р4) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест4 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
