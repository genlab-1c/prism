// Эталон B11 под СИНТЕТИЧЕСКУЮ схему (Склад, Номенклатура, ресурс Количество).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Только поля синтетической схемы — никаких реквизитов УТ11.
//
// Ключ задачи: виртуальная таблица .Остатки уже нетит приход − расход, поэтому
// КоличествоОстаток — это ЧИСТЫЙ остаток (40 у Товара1, а не 100). Товар без
// движений в выборку не попадает → остаток считаем равным 0 (ЕСТЬNULL не спасёт
// при пустой выборке, поэтому начальное значение Остаток = 0 до чтения).

Функция ДостаточноЛиОстатка(Номенклатура, Склад, ТребуемоеКоличество) Экспорт

	Запрос = Новый Запрос;
	// Внутри параметров виртуальной таблицы .Остатки(...) условия пишутся
	// по голым именам измерений — без алиаса таблицы.
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(Остатки.КоличествоОстаток, 0) КАК Остаток
	|ИЗ
	|	РегистрНакопления.ОстаткиТоваров.Остатки(, Склад = &Склад И Номенклатура = &Номенклатура) КАК Остатки";

	Запрос.УстановитьПараметр("Склад", Склад);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	// Если движений по товару нет — выборка пуста, остаток остаётся 0 (не исключение).
	Остаток = 0;
	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Остаток = Выборка.Остаток;
	КонецЕсли;

	Возврат Остаток >= ТребуемоеКоличество;

КонецФункции
