// Проверки B7 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар3 = Спр("Номенклатура", "Товар 3");

	// Тест 1: дата ДО смены цены — действует первая цена 100.
	Попытка
		Ц1 = КодКандидата.{{ENTRY}}(Товар1, Дата(2026, 2, 1));
		Если Ц1 = 100 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (цена=" + Ц1 + ", ждали 100); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: дата ПОСЛЕ смены цены — действует новая цена 150.
	Попытка
		Ц2 = КодКандидата.{{ENTRY}}(Товар1, Дата(2026, 4, 1));
		Если Ц2 = 150 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (цена=" + Ц2 + ", ждали 150); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: товар без цены — возвращается 0.
	Попытка
		Ц3 = КодКандидата.{{ENTRY}}(Товар3, Дата(2026, 4, 1));
		Если Ц3 = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (без цены ждали 0, цена=" + Ц3 + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
