// Эталон B7 под СИНТЕТИЧЕСКУЮ схему (ЦеныЗакупки: измерение Номенклатура; ресурс Цена).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Срез последних периодического РС возвращает цену, действующую на дату.

Функция ПолучитьЦену(Номенклатура, ДатаЦены) Экспорт

	Запрос = Новый Запрос;
	// Внутри параметров .СрезПоследних(Дата, Отбор) условие — по голому имени
	// измерения, без алиаса таблицы.
	Запрос.Текст =
	"ВЫБРАТЬ
	|   Цены.Цена КАК Цена
	|ИЗ
	|   РегистрСведений.ЦеныЗакупки.СрезПоследних(
	|       &ДатаЦены, Номенклатура = &Номенклатура) КАК Цены";
	Запрос.УстановитьПараметр("ДатаЦены", ДатаЦены);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	КонецЕсли;

	// Цены на дату нет — записей в срезе не вернулось.
	Возврат 0;

КонецФункции
