// Эталон B1 под СИНТЕТИЧЕСКУЮ схему (Склад, Номенклатура, ресурс ВНаличии).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Не использует поля УТ11 (Характеристика/Серия/КОтгрузке) — их в синтетике нет.

Функция ПолучитьОстаткиТоваров(МассивНоменклатуры, Склад, ГруппаНоменклатуры = Неопределено) Экспорт

    // Внутри параметров виртуальной таблицы .Остатки(...) условия пишутся
    // по голым именам измерений — без алиаса таблицы.
    Условия = "Склад = &Склад";
    Если МассивНоменклатуры <> Неопределено И МассивНоменклатуры.Количество() > 0 Тогда
        Условия = Условия + " И Номенклатура В (&МассивНоменклатуры)";
    КонецЕсли;
    Если ЗначениеЗаполнено(ГруппаНоменклатуры) Тогда
        Условия = Условия + " И Номенклатура В ИЕРАРХИИ (&ГруппаНоменклатуры)";
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Остатки.Номенклатура КАК Номенклатура,
    |   ЕСТЬNULL(Остатки.ВНаличииОстаток, 0) КАК Остаток
    |ИЗ
    |   РегистрНакопления.ТоварыНаСкладах.Остатки(, " + Условия + ") КАК Остатки";

    Запрос.УстановитьПараметр("Склад", Склад);
    Запрос.УстановитьПараметр("МассивНоменклатуры", МассивНоменклатуры);
    Если ЗначениеЗаполнено(ГруппаНоменклатуры) Тогда
        Запрос.УстановитьПараметр("ГруппаНоменклатуры", ГруппаНоменклатуры);
    КонецЕсли;

    Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
