// Проверки B1 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Миграция на YAXUNIT — отдельным шагом (формат проверок сохранится по смыслу).

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 2; Лог = "";
	СоздатьФикстуры();

	// Тест 1: остатки только по запрошенному складу (не суммировать чужие склады).
	Попытка
		М = Новый Массив; М.Добавить(Спр("Номенклатура", "Холодильник X"));
		Р1 = КодКандидата.{{ENTRY}}(М, Спр("Склады", "Основной склад"));
		Если Р1.Количество() = 1 И ЧисловаяКолонка(Р1, 0) = 5 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (строк=" + Р1.Количество() + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: фильтр по группе включает подгруппы (В ИЕРАРХИИ) и исключает чужие.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Новый Массив, Спр("Склады", "Основной склад"),
		                            Спр("Номенклатура", "Бытовая техника"));
		Н2 = Р2.ВыгрузитьКолонку("Номенклатура");
		ЕстьХолодильник = Н2.Найти(Спр("Номенклатура", "Холодильник X")) <> Неопределено;
		НетБолта = Н2.Найти(Спр("Номенклатура", "Болт М6")) = Неопределено;
		Если ЕстьХолодильник И НетБолта Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (группа/исключение); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Первая числовая колонка строки — остаток без привязки к имени колонки кандидата.
Функция ЧисловаяКолонка(ТЗ, Индекс)
	Строка = ТЗ[Индекс];
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Значение = Строка[Колонка.Имя];
		Если ТипЗнч(Значение) = Тип("Число") Тогда Возврат Значение; КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
