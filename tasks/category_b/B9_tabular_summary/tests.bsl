// Проверки B9 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 2; Лог = "";
	СоздатьФикстуры();

	СсылкаНаДокумент = СоздатьЗаказ();

	// Тест 1: свод схлопывает дубли номенклатуры — на 3 строки одна повторяется → 2 строки.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(СсылкаНаДокумент);
		Если Р1.Количество() = 2 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (строк=" + Р1.Количество() + ", ждали 2); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: суммы по Товар1 сложены: Количество 2+3=5, Сумма 200+300=500.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(СсылкаНаДокумент);
		Стр = НайтиСтроку(Р2, Спр("Номенклатура", "Товар 1"));
		Если Стр <> Неопределено
			И Колонка(Р2, Стр, "Количество", 0) = 5
			И Колонка(Р2, Стр, "Сумма", 1) = 500 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ждали Товар1 Количество=5 Сумма=500); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Документ-заказ с дублями номенклатуры: Товар1(2;200), Товар1(3;300), Товар2(10;1000).
Функция СоздатьЗаказ()
	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар2 = Спр("Номенклатура", "Товар 2");

	Док = Документы.ЗаказПокупателя.СоздатьДокумент();
	Док.Дата = ТекущаяДата();

	С1 = Док.Товары.Добавить();
	С1.Номенклатура = Товар1; С1.Количество = 2; С1.Сумма = 200;
	С2 = Док.Товары.Добавить();
	С2.Номенклатура = Товар1; С2.Количество = 3; С2.Сумма = 300;
	С3 = Док.Товары.Добавить();
	С3.Номенклатура = Товар2; С3.Количество = 10; С3.Сумма = 1000;

	Док.Записать();
	Возврат Док.Ссылка;
КонецФункции

// Поиск строки результата по номенклатуре без привязки к имени колонки-ссылки.
Функция НайтиСтроку(ТЗ, НоменклатураСсылка)
	Для Каждого Строка Из ТЗ Цикл
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Если Строка[Колонка.Имя] = НоменклатураСсылка Тогда
				Возврат Строка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Числовое значение колонки: по имени, а при его отсутствии — N-я числовая колонка
// строки по смыслу (0 — количество/первая, 1 — сумма/вторая).
Функция Колонка(ТЗ, Строка, ИмяКолонки, ПорядковыйНомерЧисловой)
	Если ТЗ.Колонки.Найти(ИмяКолонки) <> Неопределено Тогда
		Возврат Строка[ИмяКолонки];
	КонецЕсли;
	Счётчик = 0;
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Значение = Строка[Колонка.Имя];
		Если ТипЗнч(Значение) = Тип("Число") Тогда
			Если Счётчик = ПорядковыйНомерЧисловой Тогда
				Возврат Значение;
			КонецЕсли;
			Счётчик = Счётчик + 1;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
