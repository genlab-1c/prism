// Эталон B9 под синтетическую схему (Документ.ЗаказПокупателя.Товары:
// Номенклатура, Количество, Сумма). Обязан проходить tests.bsl на 100%
// против сгенерированной базы.
// Свод табличной части одним запросом: группировка по номенклатуре с
// суммированием количества и суммы — без дедупликации в коде.

Функция СвернутьТовары(ДокументСсылка) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Товары.Номенклатура КАК Номенклатура,
	|	СУММА(Товары.Количество) КАК Количество,
	|	СУММА(Товары.Сумма) КАК Сумма
	|ИЗ
	|	Документ.ЗаказПокупателя.Товары КАК Товары
	|ГДЕ
	|	Товары.Ссылка = &Ссылка
	|СГРУППИРОВАТЬ ПО
	|	Товары.Номенклатура";
	Запрос.УстановитьПараметр("Ссылка", ДокументСсылка);

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
