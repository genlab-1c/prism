// Проверки B16 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// Тест 1: ЮрЛицо → две строки, упорядочены по наименованию (ООО Альфа, ООО Гамма).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Перечисления.ЮридическийСтатус.ЮрЛицо);
		Если Р1.Количество() = 2 И Р1[0].Наименование = "ООО Альфа"
				И Р1[1].Наименование = "ООО Гамма" Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидались 2 ЮрЛица по порядку, получено "
				+ Р1.Количество() + " строк); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: ИП → одна строка (ИП Петров), и это именно тот контрагент.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Перечисления.ЮридическийСтатус.ИП);
		Если Р2.Количество() = 1 И Р2[0].Контрагент = Спр("Контрагенты", "ИП Петров") Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидался 1 ИП, получено " + Р2.Количество() + " строк); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: Прочее → пустая таблица (ни одного носителя статуса).
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Перечисления.ЮридическийСтатус.Прочее);
		Если Р3.Количество() = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалась пустая таблица, получено "
				+ Р3.Количество() + " строк); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
