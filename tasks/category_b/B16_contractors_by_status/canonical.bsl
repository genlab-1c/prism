// Эталон B16 под СИНТЕТИЧЕСКУЮ схему (справочник Контрагенты + перечисление
// ЮридическийСтатус). Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Ловушка задачи: фильтровать по ЗНАЧЕНИЮ перечисления через параметр-ссылку
// (ГДЕ ЮридическийСтатус = &Статус), а не сравнивать со строкой "ЮрЛицо".

Функция ПолучитьКонтрагентовПоСтатусу(ЮридическийСтатус) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Контрагенты.Ссылка КАК Контрагент,
	|	Контрагенты.Наименование КАК Наименование
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ЮридическийСтатус = &Статус
	|УПОРЯДОЧИТЬ ПО
	|	Наименование";

	Запрос.УстановитьПараметр("Статус", ЮридическийСтатус);

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
