// Эталон B5 под синтетическую схему (КурсыВалют: Валюта; Курс, Кратность).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.

Процедура ПересчитатьСуммыДокумента(ТабличнаяЧасть, ИсходнаяВалюта, НоваяВалюта, ДатаКурса) Экспорт

    КоэффициентИз = КурсКБазовой(ИсходнаяВалюта, ДатаКурса);
    КоэффициентВ = КурсКБазовой(НоваяВалюта, ДатаКурса);

    Для Каждого Строка Из ТабличнаяЧасть Цикл
        Строка.Цена = Окр(Строка.Цена * КоэффициентИз / КоэффициентВ, 2);
        Строка.Сумма = Окр(Строка.Цена * Строка.Количество, 2);
    КонецЦикла;

КонецПроцедуры

// Курс валюты к базовой с учётом кратности (срез последних на дату).
// Курса нет → исключение (требование задачи).
Функция КурсКБазовой(Валюта, ДатаКурса)

    Отбор = Новый Структура("Валюта", Валюта);
    Срез = РегистрыСведений.КурсыВалют.СрезПоследних(ДатаКурса, Отбор);
    Если Срез.Количество() = 0 Или Срез[0].Кратность = 0 Тогда
        ВызватьИсключение "Не найден курс валюты «" + Валюта + "» на " + Формат(ДатаКурса, "ДЛФ=Д");
    КонецЕсли;
    Возврат Срез[0].Курс / Срез[0].Кратность;

КонецФункции
