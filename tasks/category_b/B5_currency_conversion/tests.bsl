// Проверки B5 — родной формат раннера категории B (v1).
// {{ENTRY}} — процедура кандидата: (ТабличнаяЧасть, ВалютаИз, ВалютаВ, ДатаКурса),
// меняет Цена/Сумма строк по месту через кросс-курс.
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	USD = Спр("Валюты", "USD");
	EUR = Спр("Валюты", "EUR");
	JPY = Спр("Валюты", "JPY");
	MNT = Спр("Валюты", "MNT");
	ДатаКурса = Дата(2026, 2, 1);

	// Тест 1: USD → EUR (кратность 1): цена 90 → 81, сумма 2·81 = 162.
	Попытка
		Товары = НоваяТЧ(2, 90, 180);
		КодКандидата.{{ENTRY}}(Товары, USD, EUR, ДатаКурса);
		Если Товары[0].Цена = 81 И Товары[0].Сумма = 162 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (цена=" + Товары[0].Цена + ", сумма=" + Товары[0].Сумма + ", ждали 81/162); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: USD → JPY (кратность 100): цена 90 → 90·90/(60/100) = 13500.
	Попытка
		Товары = НоваяТЧ(1, 90, 90);
		КодКандидата.{{ENTRY}}(Товары, USD, JPY, ДатаКурса);
		Если Товары[0].Цена = 13500 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (цена=" + Товары[0].Цена + ", ждали 13500); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: у MNT нет курса на дату → обязано быть исключение.
	Попытка
		Товары = НоваяТЧ(1, 90, 90);
		КодКандидата.{{ENTRY}}(Товары, USD, MNT, ДатаКурса);
		Лог = Лог + "тест3 FAIL (нет курса, а исключения не было); ";
	Исключение
		Прошло = Прошло + 1;
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Табличная часть «Товары» нового документа с одной строкой.
Функция НоваяТЧ(Количество, Цена, Сумма)
	Док = Документы.ЗаказКлиента.СоздатьДокумент();
	Док.Дата = ТекущаяДата();
	Строка = Док.Товары.Добавить();
	Строка.Номенклатура = Спр("Номенклатура", "Холодильник X");
	Строка.Количество = Количество;
	Строка.Цена = Цена;
	Строка.Сумма = Сумма;
	Возврат Док.Товары;
КонецФункции
