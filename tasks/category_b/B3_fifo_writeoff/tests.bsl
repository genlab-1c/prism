// Проверки B3 — родной формат раннера категории B (v1).
// {{ENTRY}} — функция кандидата: (ТаблицаТоваров{Номенклатура, Количество}, Склад) →
// ТЗ распределения {Номенклатура, Партия, Количество, Стоимость}, FIFO по дате партии.
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Хол = Спр("Номенклатура", "Холодильник X");
	Болт = Спр("Номенклатура", "Болт М6");
	Скл = Спр("Склады", "Основной склад");

	// Тест 1: списание 15 — ранняя партия закрывается первой (10), остаток из второй (5).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(ТаблицаКСписанию(Хол, 15), Скл);
		Если Р1.Количество() = 2
			И Р1[0].Количество = 10 И Р1[1].Количество = 5
			И Р1[0].Партия.Дата < Р1[1].Партия.Дата Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (строк=" + Р1.Количество() + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: стоимость списания по цене КАЖДОЙ партии (10·100=1000 и 5·200=1000).
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(ТаблицаКСписанию(Хол, 15), Скл);
		Если Р2.Количество() = 2 И Р2[0].Стоимость = 1000 И Р2[1].Стоимость = 1000 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (стоимости по партиям); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: недостаток остатков (50 > 30) — обязано быть исключение.
	Попытка
		КодКандидата.{{ENTRY}}(ТаблицаКСписанию(Хол, 50), Скл);
		Лог = Лог + "тест3 FAIL (недостаток, а исключения не было); ";
	Исключение
		Прошло = Прошло + 1;
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Таблица товаров к списанию с одной строкой.
Функция ТаблицаКСписанию(Номенклатура, Количество)
	Т = Новый ТаблицаЗначений;
	Т.Колонки.Добавить("Номенклатура");
	Т.Колонки.Добавить("Количество");
	Строка = Т.Добавить();
	Строка.Номенклатура = Номенклатура;
	Строка.Количество = Количество;
	Возврат Т;
КонецФункции
