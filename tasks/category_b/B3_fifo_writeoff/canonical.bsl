// Эталон B3 под синтетическую схему (ПартииТоваровНаСкладах: Склад, Номенклатура,
// Партия → ДокументСсылка.ПоступлениеТоваров; Количество, Стоимость).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.

Функция СписатьПоFIFO(ТаблицаТоваров, Склад) Экспорт

    НоменклатураСтрок = ТаблицаТоваров.ВыгрузитьКолонку("Номенклатура");

    // Остатки партий одним запросом, ранние партии первыми (FIFO — по дате партии).
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Остатки.Номенклатура КАК Номенклатура,
    |   Остатки.Партия КАК Партия,
    |   Остатки.КоличествоОстаток КАК Количество,
    |   Остатки.СтоимостьОстаток КАК Стоимость
    |ИЗ
    |   РегистрНакопления.ПартииТоваровНаСкладах.Остатки(
    |       , Склад = &Склад И Номенклатура В (&НоменклатураСтрок)) КАК Остатки
    |
    |УПОРЯДОЧИТЬ ПО
    |   Остатки.Партия.Дата";
    Запрос.УстановитьПараметр("Склад", Склад);
    Запрос.УстановитьПараметр("НоменклатураСтрок", НоменклатураСтрок);
    Партии = Запрос.Выполнить().Выгрузить();

    Распределение = Новый ТаблицаЗначений;
    Распределение.Колонки.Добавить("Номенклатура");
    Распределение.Колонки.Добавить("Партия");
    Распределение.Колонки.Добавить("Количество");
    Распределение.Колонки.Добавить("Стоимость");

    Для Каждого СтрокаСписания Из ТаблицаТоваров Цикл
        ОсталосьСписать = СтрокаСписания.Количество;
        Для Каждого СтрокаПартии Из Партии Цикл
            Если ОсталосьСписать <= 0 Тогда
                Прервать;
            КонецЕсли;
            Если СтрокаПартии.Номенклатура <> СтрокаСписания.Номенклатура
                Или СтрокаПартии.Количество <= 0 Тогда
                Продолжить;
            КонецЕсли;
            Списываем = Мин(ОсталосьСписать, СтрокаПартии.Количество);
            ЦенаПартии = СтрокаПартии.Стоимость / СтрокаПартии.Количество;

            Строка = Распределение.Добавить();
            Строка.Номенклатура = СтрокаСписания.Номенклатура;
            Строка.Партия = СтрокаПартии.Партия;
            Строка.Количество = Списываем;
            Строка.Стоимость = Списываем * ЦенаПартии;

            СтрокаПартии.Количество = СтрокаПартии.Количество - Списываем;
            ОсталосьСписать = ОсталосьСписать - Списываем;
        КонецЦикла;

        Если ОсталосьСписать > 0 Тогда
            ВызватьИсключение "Недостаточно остатков для списания: "
                + СтрокаСписания.Номенклатура + " (не хватает " + ОсталосьСписать + ")";
        КонецЕсли;
    КонецЦикла;

    Возврат Распределение;

КонецФункции
