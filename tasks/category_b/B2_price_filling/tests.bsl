// Проверки B2 — родной формат раннера категории B (v1).
// {{ENTRY}} — процедура кандидата: (ТабличнаяЧасть, ВидЦен, Дата), заполняет
// Цена/Сумма строк по месту срезом последних из РС ЦеныНоменклатуры.
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Хол = Спр("Номенклатура", "Холодильник X");
	Болт = Спр("Номенклатура", "Болт М6");
	Опт = Спр("ВидыЦен", "Оптовая");

	// Тест 1: актуальная цена на позднюю дату (после смены) + пересчёт суммы.
	Попытка
		Товары = НоваяТЧ(Хол, 2);
		КодКандидата.{{ENTRY}}(Товары, Опт, Дата(2026, 4, 1));
		Если Товары[0].Цена = 120 И Товары[0].Сумма = 240 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (цена=" + Товары[0].Цена + ", сумма=" + Товары[0].Сумма + ", ждали 120/240); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: срез на дату ДО смены цены — действует старая цена.
	Попытка
		Товары = НоваяТЧ(Хол, 2);
		КодКандидата.{{ENTRY}}(Товары, Опт, Дата(2026, 2, 1));
		Если Товары[0].Цена = 100 И Товары[0].Сумма = 200 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (цена=" + Товары[0].Цена + ", ждали 100); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: товар без цены — нулевые цена и сумма (и чужой вид цен не подмешан).
	Попытка
		Товары = НоваяТЧ(Болт, 5);
		КодКандидата.{{ENTRY}}(Товары, Опт, Дата(2026, 4, 1));
		Если Товары[0].Цена = 0 И Товары[0].Сумма = 0 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (без цены ждали 0/0, цена=" + Товары[0].Цена + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Табличная часть «Товары» нового документа с одной строкой (цена/сумма пустые).
Функция НоваяТЧ(Номенклатура, Количество)
	Док = Документы.РеализацияТоваров.СоздатьДокумент();
	Док.Дата = ТекущаяДата();
	Строка = Док.Товары.Добавить();
	Строка.Номенклатура = Номенклатура;
	Строка.Количество = Количество;
	Возврат Док.Товары;
КонецФункции
