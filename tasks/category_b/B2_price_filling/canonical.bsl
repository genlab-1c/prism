// Эталон B2 под синтетическую схему (ЦеныНоменклатуры: Номенклатура, ВидЦен; Цена).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Один запрос на всю табличную часть (срез последних) — без запроса в цикле.

Процедура ЗаполнитьЦеныТабличнойЧасти(ТабличнаяЧасть, ВидЦен, ДатаЦен) Экспорт

    НоменклатураСтрок = ТабличнаяЧасть.ВыгрузитьКолонку("Номенклатура");

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |   Цены.Номенклатура КАК Номенклатура,
    |   Цены.Цена КАК Цена
    |ИЗ
    |   РегистрСведений.ЦеныНоменклатуры.СрезПоследних(
    |       &ДатаЦен, ВидЦен = &ВидЦен И Номенклатура В (&НоменклатураСтрок)) КАК Цены";
    Запрос.УстановитьПараметр("ДатаЦен", ДатаЦен);
    Запрос.УстановитьПараметр("ВидЦен", ВидЦен);
    Запрос.УстановитьПараметр("НоменклатураСтрок", НоменклатураСтрок);

    Цены = Новый Соответствие;
    Выборка = Запрос.Выполнить().Выбрать();
    Пока Выборка.Следующий() Цикл
        Цены.Вставить(Выборка.Номенклатура, Выборка.Цена);
    КонецЦикла;

    Для Каждого Строка Из ТабличнаяЧасть Цикл
        Цена = Цены.Получить(Строка.Номенклатура);
        Строка.Цена = ?(Цена = Неопределено, 0, Цена);
        Строка.Сумма = Строка.Количество * Строка.Цена;
    КонецЦикла;

КонецПроцедуры
