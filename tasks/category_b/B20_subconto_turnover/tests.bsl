// Проверки B20 — родной формат раннера категории B (v1).
// СоздатьФикстуры() создаёт виды субконто, счета (с разным порядком субконто) и проводки.
// {{ENTRY}} — имя функции кандидата. Счёт ищем по коду, контрагента — через Спр().
// Контракт: "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Счет62 = ПланыСчетов.Основной.НайтиПоКоду("62");   // субконто (Контрагент, Договор)
	Счет76 = ПланыСчетов.Основной.НайтиПоКоду("76");   // субконто (Договор, Контрагент)
	Альфа  = Спр("Контрагенты", "ООО Альфа");
	Бета   = Спр("Контрагенты", "ООО Бета");

	// Тест 1: счёт 62, К1 — две проводки по разным договорам (1000+500) → 1500 (свернуть по контрагенту).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Счет62, Альфа);
		Если Р1 = 1500 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидалось 1500, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: счёт 76, К1 — контрагент на ВТОРОЙ позиции субконто → 300.
	// Ловушка: наивный СубконтоДт1 = &Контрагент ловит договор → 0.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Счет76, Альфа);
		Если Р2 = 300 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось 300, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: счёт 62, К2 — одна проводка → 700.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Счет62, Бета);
		Если Р3 = 700 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалось 700, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
