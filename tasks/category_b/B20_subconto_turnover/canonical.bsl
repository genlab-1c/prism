// Эталон B20 под СИНТЕТИЧЕСКУЮ схему (регистр бухгалтерии с субконто, разный порядок
// субконто на счетах). Обязан проходить tests.bsl на 100%.
// Ключевое: контрагент может быть субконто на ЛЮБОЙ позиции (СубконтоДт1 или СубконтоДт2),
// поэтому матчим его по ОБЕИМ позициям. Типы субконто разные (Контрагенты ≠ Договоры),
// поэтому ложного совпадения договора с контрагентом не будет. Сворачиваем по контрагенту
// (без фильтра по договору) — СУММА по всем подходящим проводкам.

Функция ОборотПоСубконто(Счет, Контрагент) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Движения.Сумма), 0) КАК Оборот
	|ИЗ
	|	РегистрБухгалтерии.Хозрасчетный.ДвиженияССубконто КАК Движения
	|ГДЕ
	|	Движения.СчетДт = &Счет
	|	И (Движения.СубконтоДт1 = &Контрагент
	|		ИЛИ Движения.СубконтоДт2 = &Контрагент)";

	Запрос.УстановитьПараметр("Счет", Счет);
	Запрос.УстановитьПараметр("Контрагент", Контрагент);

	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	Возврат Выборка.Оборот;

КонецФункции
