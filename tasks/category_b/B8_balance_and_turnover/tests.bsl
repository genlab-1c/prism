// Проверки B8 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
//
// Смысл: движение ДО начала периода → начальный остаток; движения ВНУТРИ периода →
// приход; конечный остаток = начальный + приход. Имена колонок у кандидата могут
// отличаться (КоличествоНачальныйОстаток / КоличествоПриход / КоличествоКонечныйОстаток)
// — поэтому числовые колонки ищем УСТОЙЧИВО, по вхождению подстроки в имя колонки.

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 2; Лог = "";
	СоздатьФикстуры();

	НачалоПериода = Дата(2026, 2, 1);
	// КонецДня — иначе движение на 28.02 (00:00:00) отсечётся границей и приход
	// недосчитается: типичная ловушка «конца периода» виртуальной таблицы.
	КонецПериода  = КонецДня(Дата(2026, 2, 28));
	Склад = Спр("Склады", "Основной склад");
	Товар = Спр("Номенклатура", "Товар 1");

	// Тест 1: за февраль по складу Основной → у Товара1 НачальныйОстаток=10 и Приход=10.
	// (движение от 10.01 → нач.остаток; движения 05.02 и 28.02 → приход 4+6=10)
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(НачалоПериода, КонецПериода, Склад);
		Строка = НайтиСтроку(Р1, "Номенклатура", Товар);
		Если Строка = Неопределено Тогда
			Лог = Лог + "тест1 FAIL (строка Товар1 не найдена); ";
		Иначе
			НачОст = КолонкаПоПодстроке(Р1, Строка, "НАЧАЛЬНЫЙОСТАТОК", "НАЧ");
			Приход = КолонкаПоПодстроке(Р1, Строка, "ПРИХОД", "");
			Если НачОст = 10 И Приход = 10 Тогда
				Прошло = Прошло + 1;
			Иначе
				Лог = Лог + "тест1 FAIL (НачОст=" + Строка(НачОст) + " Приход=" + Строка(Приход) + "); ";
			КонецЕсли;
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: за февраль → у Товара1 КонечныйОстаток=20 (нач.10 + приход.10).
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(НачалоПериода, КонецПериода, Склад);
		Строка = НайтиСтроку(Р2, "Номенклатура", Товар);
		Если Строка = Неопределено Тогда
			Лог = Лог + "тест2 FAIL (строка Товар1 не найдена); ";
		Иначе
			КонОст = КолонкаПоПодстроке(Р2, Строка, "КОНЕЧНЫЙОСТАТОК", "КОН");
			Если КонОст = 20 Тогда
				Прошло = Прошло + 1;
			Иначе
				Лог = Лог + "тест2 FAIL (КонОст=" + Строка(КонОст) + "); ";
			КонецЕсли;
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Поиск строки ТЗ по колонке, чьё имя содержит ИскомоеИмя, со значением = ЗначениеОтбора.
// Имя колонки сопоставляем по вхождению (без учёта регистра) — у кандидата может быть
// «Номенклатура», но на всякий случай ищем устойчиво.
Функция НайтиСтроку(ТЗ, ИскомоеИмя, ЗначениеОтбора)
	ИмяКолонки = ИмяКолонкиПоПодстроке(ТЗ, ВРег(ИскомоеИмя), "");
	Если ИмяКолонки = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Для Каждого Стр Из ТЗ Цикл
		Если Стр[ИмяКолонки] = ЗначениеОтбора Тогда
			Возврат Стр;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Имя колонки ТЗ, содержащей одну из подстрок (без учёта регистра). Сначала ищем по
// Подстрока1, затем по Подстрока2 (запасной вариант, например короткое «Нач»/«Кон»).
// Пустая подстрока пропускается.
Функция ИмяКолонкиПоПодстроке(ТЗ, Подстрока1, Подстрока2)
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		ИмяВРег = ВРег(Колонка.Имя);
		Если Не ПустаяСтрока(Подстрока1) И Найти(ИмяВРег, ВРег(Подстрока1)) > 0 Тогда
			Возврат Колонка.Имя;
		КонецЕсли;
	КонецЦикла;
	Если Не ПустаяСтрока(Подстрока2) Тогда
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Если Найти(ВРег(Колонка.Имя), ВРег(Подстрока2)) > 0 Тогда
				Возврат Колонка.Имя;
			КонецЕсли;
		КонецЦикла;
	КонецЕсли;
	Возврат Неопределено;
КонецФункции

// Числовое значение строки из колонки, чьё имя содержит подстроку (без учёта регистра).
// Возврат Неопределено, если подходящей колонки нет.
Функция КолонкаПоПодстроке(ТЗ, Строка, Подстрока1, Подстрока2)
	ИмяКолонки = ИмяКолонкиПоПодстроке(ТЗ, Подстрока1, Подстрока2);
	Если ИмяКолонки = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Строка[ИмяКолонки];
КонецФункции
