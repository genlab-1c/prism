// Эталон B8 под СИНТЕТИЧЕСКУЮ схему (Склад, Номенклатура, ресурс Количество).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
//
// Виртуальная таблица .ОстаткиИОбороты(НачалоПериода, КонецПериода, Периодичность,
// МетодДополнения, Условие) — лишние позиционные параметры (Периодичность,
// МетодДополнения) пропускаем запятыми. Ресурсы ВТ остатков-и-оборотов для ресурса
// «Количество»: КоличествоНачальныйОстаток, КоличествоПриход, КоличествоРасход,
// КоличествоКонечныйОстаток.

Функция ПолучитьОстаткиИОбороты(НачалоПериода, КонецПериода, Склад = Неопределено) Экспорт

	// Условие ВТ пишется по ГОЛЫМ именам измерений — без алиаса таблицы.
	// Накладываем фильтр по складу, только если он задан.
	Условие = "";
	Если ЗначениеЗаполнено(Склад) Тогда
		Условие = "Склад = &Склад";
	КонецЕсли;

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОстаткиИОбороты.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОстаткиИОбороты.КоличествоНачальныйОстаток, 0) КАК НачальныйОстаток,
	|	ЕСТЬNULL(ОстаткиИОбороты.КоличествоПриход, 0) КАК Приход,
	|	ЕСТЬNULL(ОстаткиИОбороты.КоличествоРасход, 0) КАК Расход,
	|	ЕСТЬNULL(ОстаткиИОбороты.КоличествоКонечныйОстаток, 0) КАК КонечныйОстаток
	|ИЗ
	|	РегистрНакопления.ДвиженияТоваров.ОстаткиИОбороты(&НачалоПериода, &КонецПериода, , , " + Условие + ") КАК ОстаткиИОбороты";

	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);
	Если ЗначениеЗаполнено(Склад) Тогда
		Запрос.УстановитьПараметр("Склад", Склад);
	КонецЕсли;

	Возврат Запрос.Выполнить().Выгрузить();

КонецФункции
