// Проверки B13 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Миграция на YAXUNIT — отдельным шагом (формат проверок сохранится по смыслу).

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// Тест 1: 3 коробки по 12 → 36 (умножение, не деление).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Спр("Упаковки", "Коробка"), 3);
		Если Р1 = 36 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (получено=" + Р1 + ", ожидалось 36); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: 2 палеты по 480 → 960 (крупный коэффициент).
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Спр("Упаковки", "Палета"), 2);
		Если Р2 = 960 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (получено=" + Р2 + ", ожидалось 960); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: 5 штук по 1 → 5 (базовая единица, коэффициент = 1).
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Спр("Упаковки", "Штука"), 5);
		Если Р3 = 5 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (получено=" + Р3 + ", ожидалось 5); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
