// Проверки B17 — родной формат раннера категории B (v1).
// СоздатьФикстуры() и Спр() генерируются харнессом из fixtures.yaml. {{ENTRY}} — имя
// функции кандидата; код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();
	Товар = Спр("Номенклатура", "Товар А");
	Вид = Спр("ВидыЦен", "Розница");

	// Тест 1: на 2026-02-15 актуальна цена от 2026-02-01 → 120.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Товар, Вид, Дата(2026, 2, 15));
		Если Р1 = 120 Тогда Прошло = Прошло + 1;
		Иначе Лог = Лог + "тест1 FAIL (ожидалось 120, получено " + Р1 + "); "; КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: ровно на 2026-01-01 → первая установленная цена 100.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Товар, Вид, Дата(2026, 1, 1));
		Если Р2 = 100 Тогда Прошло = Прошло + 1;
		Иначе Лог = Лог + "тест2 FAIL (ожидалось 100, получено " + Р2 + "); "; КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: до первой установки (2025-12-01) цены нет → 0.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Товар, Вид, Дата(2025, 12, 1));
		Если Р3 = 0 Тогда Прошло = Прошло + 1;
		Иначе Лог = Лог + "тест3 FAIL (ожидалось 0, получено " + Р3 + "); "; КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
