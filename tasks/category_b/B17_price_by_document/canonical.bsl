// Эталон B17 под СИНТЕТИЧЕСКУЮ схему (подчинённый РС ЦеныДокументом + справочники).
// Обязан проходить tests.bsl на 100%. Ловушка: цена берётся СРЕЗОМ ПОСЛЕДНИХ на дату
// (а не последней записью вообще), с фильтром по номенклатуре и виду цены; нет записи
// на дату → 0. Подчинённость РС регистратору на чтение (срез последних) не влияет.

Функция ПолучитьЦенуНаДату(Номенклатура, ВидЦены, Дата) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Цены.Цена КАК Цена
	|ИЗ
	|	РегистрСведений.ЦеныДокументом.СрезПоследних(
	|		&Дата, Номенклатура = &Номенклатура И ВидЦены = &ВидЦены) КАК Цены";

	Запрос.УстановитьПараметр("Дата", Дата);
	Запрос.УстановитьПараметр("Номенклатура", Номенклатура);
	Запрос.УстановитьПараметр("ВидЦены", ВидЦены);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Цена;
	КонецЕсли;
	Возврат 0;

КонецФункции
