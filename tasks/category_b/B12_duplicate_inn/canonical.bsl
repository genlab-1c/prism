// Эталон B12 под СИНТЕТИЧЕСКУЮ схему (справочник Контрагенты, реквизит ИНН).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Ловушка задачи: проверка существования ДРУГОГО контрагента — сам элемент
// исключается условием Ссылка <> &Исключаемый, иначе функция всегда вернёт Истина.

Функция ЕстьДубльПоИНН(ИНН, ИсключаемыйКонтрагент) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Контрагенты.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Контрагенты КАК Контрагенты
	|ГДЕ
	|	Контрагенты.ИНН = &ИНН
	|	И Контрагенты.Ссылка <> &Исключаемый";

	Запрос.УстановитьПараметр("ИНН", ИНН);
	Запрос.УстановитьПараметр("Исключаемый", ИсключаемыйКонтрагент);

	Возврат НЕ Запрос.Выполнить().Пустой();

КонецФункции
