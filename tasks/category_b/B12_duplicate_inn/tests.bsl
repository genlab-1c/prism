// Проверки B12 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Миграция на YAXUNIT — отдельным шагом (формат проверок сохранится по смыслу).

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// Тест 1: у ИНН 7707083893 есть второй носитель → исключая К1, дубль остаётся (К2).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}("7707083893", Спр("Контрагенты", "ООО Альфа"));
		Если Р1 = Истина Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидался дубль для К1, получено " + Р1 + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: ИНН 5009053043 уникален → исключая его носителя К3, дубля нет (ловушка
	// «забыли исключить сам элемент» здесь даёт ложное Истина и валит тест).
	Попытка
		Р2 = КодКандидата.{{ENTRY}}("5009053043", Спр("Контрагенты", "ООО Гамма"));
		Если Р2 = Ложь Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось отсутствие дубля для К3, получено " + Р2 + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: тот же дубль ИНН, но исключаем другой элемент пары → остаётся К1.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}("7707083893", Спр("Контрагенты", "ООО Бета"));
		Если Р3 = Истина Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидался дубль для К2, получено " + Р3 + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
