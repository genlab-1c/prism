// Проверки B19 — родной формат раннера категории B (v1).
// СоздатьФикстуры() создаёт счета (с субсчетами) и проводки; ниже — только проверки.
// {{ENTRY}} — имя функции кандидата. Счета ищем по коду. Контракт: "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Счет62 = ПланыСчетов.Основной.НайтиПоКоду("62");   // проводки только на субсчетах
	Счет60 = ПланыСчетов.Основной.НайтиПоКоду("60");   // пассивный
	Счет51 = ПланыСчетов.Основной.НайтиПоКоду("51");   // активный

	// Тест 1: сальдо 62 = дебет(1000+500) − кредит(300) по иерархии субсчетов = 1200.
	// Ловушки: без В ИЕРАРХИИ → 0; «дебетовый оборот» → 1500.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Счет62);
		Если Р1 = 1200 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидалось 1200, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: счёт 60 ПАССИВНЫЙ → кредитовое сальдо = кредит(800) − дебет(200) = 600.
	// Ловушка: дебет−кредит = −600.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Счет60);
		Если Р2 = 600 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось 600, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: счёт 51 АКТИВНЫЙ → дебетовое сальдо = дебет(300) − кредит(200) = 100.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Счет51);
		Если Р3 = 100 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалось 100, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
