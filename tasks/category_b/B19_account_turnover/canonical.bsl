// Эталон B19 под СИНТЕТИЧЕСКУЮ схему (регистр бухгалтерии + план счетов с субсчетами).
// Обязан проходить tests.bsl на 100%.
// Ключевое: (1) отбор В ИЕРАРХИИ — учесть проводки субсчетов; (2) нетто Дт−Кт по
// иерархии; (3) знак по Виду счёта — для пассивного вернуть кредитовое сальдо.

Функция СальдоПоСчету(Счет) Экспорт

	// В ИЕРАРХИИ нельзя внутри агрегатной функции → разносим дебет и кредит в подзапросы
	// (там В ИЕРАРХИИ в ГДЕ), а нетто считаем во внешней СУММА.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ЕСТЬNULL(СУММА(Стороны.Знак * Стороны.Сумма), 0) КАК НеттоДебет
	|ИЗ
	|	(ВЫБРАТЬ
	|		1 КАК Знак,
	|		Движения.Сумма КАК Сумма
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный КАК Движения
	|	ГДЕ
	|		Движения.СчетДт В ИЕРАРХИИ(&Счет)
	|	ОБЪЕДИНИТЬ ВСЕ
	|	ВЫБРАТЬ
	|		-1,
	|		Движения.Сумма
	|	ИЗ
	|		РегистрБухгалтерии.Хозрасчетный КАК Движения
	|	ГДЕ
	|		Движения.СчетКт В ИЕРАРХИИ(&Счет)) КАК Стороны";

	Запрос.УстановитьПараметр("Счет", Счет);

	Выборка = Запрос.Выполнить().Выбрать();
	Выборка.Следующий();
	НеттоДебет = Выборка.НеттоДебет;

	// пассивный счёт — сальдо кредитовое (кредит минус дебет)
	Если Счет.Вид = ВидСчета.Пассивный Тогда
		Возврат -НеттоДебет;
	Иначе
		Возврат НеттоДебет;
	КонецЕсли;

КонецФункции
