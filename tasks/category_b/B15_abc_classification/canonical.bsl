// Эталон B15 под СИНТЕТИЧЕСКУЮ схему (Номенклатура, ресурс Сумма).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Регистр «Продажи» — ОБОРОТНЫЙ: в виртуальной таблице .Обороты ресурс получает
// суффикс «Оборот» → СуммаОборот.
// Ловушка: сортировка по обороту убыв. + накопительный процент + границы классов.
// Не использует поля, которых нет в синтетической схеме.

Функция КлассификацияABC(НачалоПериода, КонецПериода) Экспорт

	// Шаг 1. Обороты по номенклатуре за период, сразу упорядоченные по убыванию —
	// порядок сортировки критичен для накопительной доли.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	ОборотыПродаж.Номенклатура КАК Номенклатура,
	|	ЕСТЬNULL(ОборотыПродаж.СуммаОборот, 0) КАК СуммаОборот
	|ИЗ
	|	РегистрНакопления.Продажи.Обороты(&НачалоПериода, &КонецПериода) КАК ОборотыПродаж
	|УПОРЯДОЧИТЬ ПО
	|	СуммаОборот УБЫВ";

	Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
	Запрос.УстановитьПараметр("КонецПериода", КонецПериода);

	ТаблицаОборотов = Запрос.Выполнить().Выгрузить();

	// Шаг 2. Общий оборот за период (знаменатель доли).
	ОбщийОборот = ТаблицаОборотов.Итог("СуммаОборот");

	// Шаг 3. Результат — таблица с колонками Номенклатура (ссылка) и Класс (строка).
	Результат = Новый ТаблицаЗначений;
	Результат.Колонки.Добавить("Номенклатура");
	Результат.Колонки.Добавить("Класс", Новый ОписаниеТипов("Строка"));

	// Деление на ноль: оборот нулевой → классифицировать нечем, возвращаем пусто.
	Если ОбщийОборот = 0 Тогда
		Возврат Результат;
	КонецЕсли;

	// Шаг 4. Идём по строкам в порядке убывания, ведём накопленную сумму.
	// ВАЖНО: накопленную долю считаем ПОСЛЕ добавления текущей строки —
	// после Товар1 накопл.=80% → A; после Товар2 =95% → B; после Товар3 =100% → C.
	НакопленнаяСумма = 0;
	Для Каждого СтрокаОборота Из ТаблицаОборотов Цикл
		НакопленнаяСумма = НакопленнаяСумма + СтрокаОборота.СуммаОборот;
		НакопленнаяДоля = НакопленнаяСумма / ОбщийОборот * 100;

		Если НакопленнаяДоля <= 80 Тогда
			Класс = "A";
		ИначеЕсли НакопленнаяДоля <= 95 Тогда
			Класс = "B";
		Иначе
			Класс = "C";
		КонецЕсли;

		НоваяСтрока = Результат.Добавить();
		НоваяСтрока.Номенклатура = СтрокаОборота.Номенклатура;
		НоваяСтрока.Класс = Класс;
	КонецЦикла;

	Возврат Результат;

КонецФункции
