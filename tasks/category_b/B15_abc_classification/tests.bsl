// Проверки B15 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Обороты за февраль: Товар1 800 (доля 80%, накопл. 80% → A), Товар2 150
// (доля 15%, накопл. 95% → B), Товар3 50 (доля 5%, накопл. 100% → C).

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Товар1 = Спр("Номенклатура", "Товар 1");
	Товар2 = Спр("Номенклатура", "Товар 2");
	Товар3 = Спр("Номенклатура", "Товар 3");

	НачалоПериода = Дата(2026, 2, 1);
	КонецПериода = Дата(2026, 2, 28);

	// Тест 1: Товар1 — крупнейший оборот (80%), накопл. доля 80% ≤ 80 → класс "A".
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(НачалоПериода, КонецПериода);
		Если НайтиКласс(Р1, Товар1) = "A" Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (Товар1 класс=" + НайтиКласс(Р1, Товар1) + ", ждали A); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: Товар2 — накопл. доля 80%+15%=95% ≤ 95 → класс "B".
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(НачалоПериода, КонецПериода);
		Если НайтиКласс(Р2, Товар2) = "B" Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (Товар2 класс=" + НайтиКласс(Р2, Товар2) + ", ждали B); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: Товар3 — накопл. доля 95%+5%=100% > 95 → класс "C".
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(НачалоПериода, КонецПериода);
		Если НайтиКласс(Р3, Товар3) = "C" Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (Товар3 класс=" + НайтиКласс(Р3, Товар3) + ", ждали C); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции

// Класс номенклатуры из результата: ищем строку по ссылке на номенклатуру и
// возвращаем значение колонки «Класс». Имя колонки у кандидата может отличаться —
// тогда берём первую строковую колонку строки (устойчиво к именам кандидата).
Функция НайтиКласс(ТЗ, НоменклатураСсылка)
	Строка = НайтиСтроку(ТЗ, НоменклатураСсылка);
	Если Строка = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	Если ТЗ.Колонки.Найти("Класс") <> Неопределено Тогда
		Возврат Строка["Класс"];
	КонецЕсли;
	// Колонка «Класс» названа иначе — первая строковая колонка строки.
	Для Каждого Колонка Из ТЗ.Колонки Цикл
		Значение = Строка[Колонка.Имя];
		Если ТипЗнч(Значение) = Тип("Строка") Тогда
			Возврат Значение;
		КонецЕсли;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции

// Строка результата по номенклатуре — без привязки к имени колонки-ссылки кандидата.
Функция НайтиСтроку(ТЗ, НоменклатураСсылка)
	Для Каждого Строка Из ТЗ Цикл
		Для Каждого Колонка Из ТЗ.Колонки Цикл
			Если Строка[Колонка.Имя] = НоменклатураСсылка Тогда
				Возврат Строка;
			КонецЕсли;
		КонецЦикла;
	КонецЦикла;
	Возврат Неопределено;
КонецФункции
