// Проверки B18 — родной формат раннера категории B (v1).
// СоздатьФикстуры() ставит значение константы; ниже — только проверки. {{ENTRY}} —
// имя функции кандидата. Сумма ВКЛЮЧАЕТ НДС, ставка 20% → НДС = Сумма·20/120.
// Ловушка: формула «сверху» Сумма·20/100 даёт 240 вместо 200. Контракт: "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// Тест 1: 1200 с НДС → НДС = 1200·20/120 = 200 (наивно «сверху» дало бы 240).
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(1200);
		Если Р1 = 200 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидалось 200, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: 6000 с НДС → 1000.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(6000);
		Если Р2 = 1000 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидалось 1000, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: 360 с НДС → 60.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(360);
		Если Р3 = 60 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалось 60, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
