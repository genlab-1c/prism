// Эталон B16 под СИНТЕТИЧЕСКУЮ схему (Контрагенты + подчинённые Договоры с интервалом).
// Обязан проходить tests.bsl на 100%.
// Ключевое: договор действует на дату, если ДатаНачала <= срез И (ДатаОкончания пустая
// ИЛИ >= срез). Пустая дата в 1С = ДАТАВРЕМЯ(1,1,1) — её надо трактовать как «бессрочно».

Функция ДействующийДоговор(Контрагент, ДатаСреза) Экспорт

	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ ПЕРВЫЕ 1
	|	Договоры.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Договоры КАК Договоры
	|ГДЕ
	|	Договоры.Владелец = &Контрагент
	|	И Договоры.ДатаНачала <= &ДатаСреза
	|	И (Договоры.ДатаОкончания = ДАТАВРЕМЯ(1, 1, 1)
	|		ИЛИ Договоры.ДатаОкончания >= &ДатаСреза)
	|УПОРЯДОЧИТЬ ПО
	|	Договоры.ДатаНачала УБЫВ";

	Запрос.УстановитьПараметр("Контрагент", Контрагент);
	Запрос.УстановитьПараметр("ДатаСреза", ДатаСреза);

	Выборка = Запрос.Выполнить().Выбрать();
	Если Выборка.Следующий() Тогда
		Возврат Выборка.Ссылка;
	Иначе
		Возврат Неопределено;
	КонецЕсли;

КонецФункции
