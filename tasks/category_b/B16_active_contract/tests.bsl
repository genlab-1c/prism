// Проверки B16 — родной формат раннера категории B (v1).
// СоздатьФикстуры() и Спр() генерируются из fixtures.yaml; ниже — только проверки.
// {{ENTRY}} — имя функции кандидата. Контракт: "PASSED=n;TOTAL=m;<лог>".

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	Альфа = Спр("Контрагенты", "ООО Альфа");
	Бета  = Спр("Контрагенты", "ООО Бета");

	// Тест 1: на 15.01.2025 действует только Д-100 (Д-200 начинается 01.02 — позже среза).
	// Ловушка «взять последний по дате начала» без проверки ДатаНачала<=срез дала бы Д-200.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(Альфа, Дата(2025,1,15));
		Если Р1 = Спр("Договоры", "Д-100") Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (ожидался Д-100, получено " + Строка(Р1) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: на 15.06.2025 действует только Д-200 (бессрочный; Д-100 закрыт 31.03).
	// Ловушка: наивный фильтр «ДатаОкончания >= срез» теряет бессрочный Д-200.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(Альфа, Дата(2025,6,15));
		Если Р2 = Спр("Договоры", "Д-200") Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (ожидался Д-200, получено " + Строка(Р2) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: на 15.06.2025 у Беты действующих нет (Д-300 закончился 31.05) → Неопределено.
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(Бета, Дата(2025,6,15));
		Если Р3 = Неопределено Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (ожидалось Неопределено, получено " + Строка(Р3) + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
