// Эталон B10 под СИНТЕТИЧЕСКУЮ схему (иерархический справочник Номенклатура).
// Обязан проходить tests.bsl на 100% против сгенерированной базы.
// Только поля синтетической схемы: Ссылка, Наименование, системный признак ЭтоГруппа.

Функция ПолучитьЭлементыГруппы(Группа) Экспорт

	// ЭтоГруппа = ЛОЖЬ → отсекаем папки, оставляем конечные элементы.
	// В ИЕРАРХИИ(&Группа) → элементы самой группы и всех подгрупп на любом уровне.
	Запрос = Новый Запрос;
	Запрос.Текст =
	"ВЫБРАТЬ
	|	Номенклатура.Ссылка КАК Ссылка
	|ИЗ
	|	Справочник.Номенклатура КАК Номенклатура
	|ГДЕ
	|	Номенклатура.ЭтоГруппа = ЛОЖЬ
	|	И Номенклатура.Ссылка В ИЕРАРХИИ (&Группа)
	|УПОРЯДОЧИТЬ ПО
	|	Номенклатура.Наименование";

	Запрос.УстановитьПараметр("Группа", Группа);

	// Выгружаем колонку Ссылка в массив — порядок сохраняется из УПОРЯДОЧИТЬ ПО.
	Возврат Запрос.Выполнить().Выгрузить().ВыгрузитьКолонку("Ссылка");

КонецФункции
