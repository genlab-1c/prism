// Проверки B10 — родной формат раннера категории B (v1).
// Модуль «Тесты» собирает харнесс: СоздатьФикстуры() и Спр() генерируются из
// fixtures.yaml, ниже — только проверки. {{ENTRY}} — имя функции кандидата
// (детекция как в категории A); код кандидата — общий модуль «КодКандидата».
// Контракт: ПрогнатьТест() возвращает строку "PASSED=n;TOTAL=m;<лог>".
// Миграция на YAXUNIT — отдельным шагом (формат проверок сохранится по смыслу).

Функция ПрогнатьТест() Экспорт
	Прошло = 0; Всего = 3; Лог = "";
	СоздатьФикстуры();

	// НайтиПоНаименованию находит и группы → так получаем ссылку на группу «Техника».
	СсылкаНаГруппу = Спр("Номенклатура", "Техника");

	// Тест 1: количество конечных элементов в группе и её подгруппах = 2.
	Попытка
		Р1 = КодКандидата.{{ENTRY}}(СсылкаНаГруппу);
		Если Р1.Количество() = 2 Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест1 FAIL (элементов=" + Р1.Количество() + "); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест1 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 2: результат содержит оба элемента подгруппы и НЕ содержит элемент чужой ветки.
	Попытка
		Р2 = КодКандидата.{{ENTRY}}(СсылкаНаГруппу);
		ЕстьХолодильник = Р2.Найти(Спр("Номенклатура", "Холодильник X")) <> Неопределено;
		ЕстьМорозильник = Р2.Найти(Спр("Номенклатура", "Морозильник М")) <> Неопределено;
		НетБолта = Р2.Найти(Спр("Номенклатура", "Болт М6")) = Неопределено;
		Если ЕстьХолодильник И ЕстьМорозильник И НетБолта Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест2 FAIL (состав/исключение); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест2 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	// Тест 3: порядок по наименованию по возрастанию → первым идёт «Морозильник М».
	Попытка
		Р3 = КодКандидата.{{ENTRY}}(СсылкаНаГруппу);
		Если Р3.Количество() > 0 И Р3[0] = Спр("Номенклатура", "Морозильник М") Тогда
			Прошло = Прошло + 1;
		Иначе
			Лог = Лог + "тест3 FAIL (порядок по наименованию); ";
		КонецЕсли;
	Исключение
		Лог = Лог + "тест3 ИСКЛЮЧЕНИЕ: " + ОписаниеОшибки() + "; ";
	КонецПопытки;

	Возврат "PASSED=" + Прошло + ";TOTAL=" + Всего + ";" + Лог;
КонецФункции
