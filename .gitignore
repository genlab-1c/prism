# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.coverage
htmlcov/

# Кэш плагинов (соцкарточки MkDocs Material и пр.)
.cache/

# Инструменты-бинари (тяжёлые, ставятся локально): BSL LS jar, OneScript, YAXUNIT, 1С.
# Сами бинари не коммитятся — в git идут только bootstrap-скрипты установки.
tools/*
!tools/get-*.sh

# Рабочие артефакты прогонов (промежуточные; канонические результаты — в results/)
work/

# Авто-оценки L1 (дериват из results/ + протокола). Кэш прогонов игнорируем, но
# КАНОНИЧЕСКИЕ снимки коммитим — чтобы `prism leaderboard` работал сразу после клона.
results/auto/*
!results/auto/experiment_A_20260617_031633_auto_l1.json
!results/auto/experiment_B_20260617_031637_auto_l1.json
!results/auto/site_data.json
# Промежуточные чекпойнты генерации (для --resume; финал — в experiment_*.json)
results/*.parts/

# Сборка документации MkDocs
site/

# Секреты и окружение
.env
*.env
!*.env.example

# IDE / OS
.idea/
.vscode/
.DS_Store

# AI-ассистент (локальные инструкции/настройки — не часть бенчмарка)
CLAUDE.md
.claude/
